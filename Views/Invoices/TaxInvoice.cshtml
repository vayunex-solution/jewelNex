@model JewelleryApp.Models.Jewellery.Invoice
@inject JewelleryApp.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Tax Invoice";
    var settings = Db.ShopSettings.FirstOrDefault() ?? new JewelleryApp.Models.Jewellery.ShopSetting();
}

<div class="no-print actions-bar">
    <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Print Tax Invoice</button>
    @if (Model.Id > 0)
    {
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Back to Details</a>
    }
    else
    {
        <button onclick="window.close()" class="btn btn-secondary">Close Preview</button>
    }
</div>

<div class="estimate-container tax-invoice">
    <div class="invoice-header-top">
        <div class="gst-pan">
            <p>GSTIN : @settings.GSTIN</p>
            <p>PAN : @settings.PAN</p>
        </div>
        <div class="invoice-title">
            <h2>TAX INVOICE</h2>
            <p>State Code : @settings.StateCode</p>
        </div>
        <div class="contact-section-top">
            <p>M. : @settings.Phone1</p>
            <p>M. : @settings.Phone2</p>
        </div>
    </div>

    <div class="estimate-header">
        <div class="top-row">
            <div class="logo-jj">
                <div class="jj-circle">JJ</div>
            </div>
            <div class="title-section">
                <h1 class="shop-name">@settings.ShopName</h1>
                <div class="tagline">@settings.Tagline</div>
            </div>
        </div>
        <div class="address-bar">
            @settings.Address1, @settings.Address2, @settings.CityState
        </div>
    </div>

    <div class="customer-info">
        <div class="info-row">
            <div class="info-item"><strong>Invoice No.</strong> <span class="invoice-num">@Model.InvoiceNo</span></div>
            <div class="info-item text-right"><strong>Dated</strong> <span class="data-field">@Model.Date.ToString("dd-MM-yyyy")</span></div>
        </div>
        <div class="info-row">
            <div class="info-item full"><strong>Name</strong> <span class="data-field">@Model.Customer?.Name</span></div>
        </div>
        <div class="info-row">
            <div class="info-item full"><strong>Address</strong> <span class="data-field">@Model.Customer?.Address</span></div>
        </div>
        <div class="info-row">
            <div class="info-item"><strong>Ph.</strong> <span class="data-field">@Model.Customer?.Mobile</span></div>
            <div class="info-item"><strong>State</strong> <span class="data-field">Haryana</span></div>
            <div class="info-item text-right"><strong>State Code</strong> <span class="data-field">06</span></div>
        </div>
        <div class="info-row">
            <div class="info-item"><strong>GSTIN</strong> <span class="data-field"></span></div>
            <div class="info-item full"><strong>AADHAAR / PAN No.</strong> <span class="data-field"></span></div>
        </div>
        <div class="info-row">
            <div class="info-item"><strong>Opening Bal (₹)</strong> <span class="data-field">@Model.Customer?.OpeningBalance.ToString("N2") @Model.Customer?.BalanceType</span></div>
            <div class="info-item"><strong>Opening Gold (g)</strong> <span class="data-field">@Model.Customer?.OpeningGold.ToString("N3") @Model.Customer?.GoldBalanceType</span></div>
            <div class="info-item text-right"><strong>Opening Silver (g)</strong> <span class="data-field">@Model.Customer?.OpeningSilver.ToString("N3") @Model.Customer?.SilverBalanceType</span></div>
        </div>
    </div>

    <table class="items-table">
        <thead>
            <tr>
                <th style="width: 3%;">S.N</th>
                <th style="width: 3%;">R/I</th>
                <th style="width: 20%;">Item</th>
                <th style="width: 6%;">HSN</th>
                <th style="width: 6%;">Metal</th>
                <th style="width: 8%;">Gross Wt</th>
                <th style="width: 6%;">Purity</th>
                <th style="width: 8%;">Fine Wt</th>
                <th style="width: 8%;">Rate</th>
                <th style="width: 8%;">Metal Amt</th>
                <th style="width: 5%;">Mk%</th>
                <th style="width: 8%;">Mk Amt</th>
                <th style="width: 10%; text-align: center;">Total</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < 10; i++)
            {
                var item = i < Model.Items.Count ? Model.Items[i] : null;
                <tr>
                    <td class="text-center">@(item != null ? (i + 1).ToString() : "")</td>
                    <td class="text-center">@(item?.RI ?? "")</td>
                    <td>@(item?.ItemName ?? "")</td>
                    <td class="text-center">@(item != null ? "7113" : "")</td>
                    <td class="text-center">@(item?.Metal ?? "")</td>
                    <td class="text-right">@(item != null ? item.GrossWt.ToString("N3") : "")</td>
                    <td class="text-center">@(item?.Purity ?? "")</td>
                    <td class="text-right">@(item != null ? item.FineWt.ToString("N3") : "")</td>
                    <td class="text-right">@(item != null ? item.Rate.ToString("N2") : "")</td>
                    <td class="text-right">@(item != null ? item.MetalAmount.ToString("N2") : "")</td>
                    <td class="text-right">@(item != null && item.MakingPercent > 0 ? item.MakingPercent.ToString("N1") + (settings.MakingChargeType == "Percentage" ? "%" : "") : (item != null ? "-" : ""))</td>
                    <td class="text-right">@(item != null && item.MakingCharges > 0 ? item.MakingCharges.ToString("N2") : (item != null ? "-" : ""))</td>
                    <td class="text-right"><strong>@(item != null ? item.Amount.ToString("N2") : "")</strong></td>
                </tr>
            }
        </tbody>
    </table>

    <div class="tax-footer-grid">
        <div class="bank-details-section">
            <div class="bank-title">Bank Details :</div>
            <p><strong>@settings.BankName</strong>, @settings.BankBranch</p>
            <p><strong>A/C No. :</strong> @settings.AccountNo</p>
            <p><strong>IFS Code :</strong> @settings.IFSCCode</p>
            
            <div class="cheque-line">
                <strong>Cheque No./Cash</strong> <span class="data-field">@Model.PaymentMode</span>
            </div>

            @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
            {
                <div class="cheque-line" style="margin-top: 5px; color: #333;">
                    <strong>Total Metal Weight</strong> <span class="data-field">@Model.Items.Sum(i => i.FineWt).ToString("N3") g</span>
                </div>
            }

            @if (Model.PrintOption == "Balance" || Model.PrintOption == "Both" || true) @* Always show closing balance as per user request *@
            {
                var customer = Model.Customer;
                if (customer != null)
                {
                    // 1. Calculate Amount Balance
                    var voucherItems = Db.VoucherItems
                        .Include(vi => vi.Voucher)
                        .Where(vi => vi.AccountName == customer.Name && vi.Voucher.Date <= Model.Date)
                        .ToList();
                        
                    decimal amountBal = (customer.BalanceType == JewelleryApp.Models.Jewellery.BalanceType.Dr) ? customer.OpeningBalance : -customer.OpeningBalance;
                    foreach (var vi in voucherItems) amountBal += (vi.Debit - vi.Credit);

                    // 2. Calculate Metal Balance
                    var invoiceItems = Db.InvoiceItems
                        .Include(ii => ii.Invoice)
                        .Where(ii => ii.Invoice.CustomerId == Model.CustomerId && ii.Invoice.Date <= Model.Date)
                        .ToList();

                    var metalVouchers = Db.Vouchers
                        .Where(v => v.AccountName == customer.Name && (v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalReceipt || v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment) && v.Date <= Model.Date)
                        .ToList();

                    decimal goldBal = (customer.GoldBalanceType == JewelleryApp.Models.Jewellery.BalanceType.Dr) ? customer.OpeningGold : -customer.OpeningGold;
                    decimal silverBal = (customer.SilverBalanceType == JewelleryApp.Models.Jewellery.BalanceType.Dr) ? customer.OpeningSilver : -customer.OpeningSilver;

                    foreach (var item in invoiceItems)
                    {
                        if (item.Metal == "Gold")
                        {
                            if (item.RI == "I") goldBal += item.FineWt;
                            else goldBal -= item.FineWt;
                        }
                        else if (item.Metal == "Silver")
                        {
                            if (item.RI == "I") silverBal += item.FineWt;
                            else silverBal -= item.FineWt;
                        }
                    }

                    foreach (var v in metalVouchers)
                    {
                        if (v.Metal == "Gold")
                        {
                            if (v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment) goldBal += v.FineWeight;
                            else goldBal -= v.FineWeight;
                        }
                        else if (v.Metal == "Silver")
                        {
                            if (v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment) silverBal += v.FineWeight;
                            else silverBal -= v.FineWeight;
                        }
                    }

                    // Add Invoice-level Metal Receipt
                    if (Model.MetalReceivedFineWeight > 0)
                    {
                        if (Model.MetalReceivedType == "Gold") goldBal -= Model.MetalReceivedFineWeight;
                        else if (Model.MetalReceivedType == "Silver") silverBal -= Model.MetalReceivedFineWeight;
                    }

                    @if (Model.PaidAmount > 0 || Model.MetalReceivedFineWeight > 0)
                    {
                        <div style="display: flex; justify-content: space-between; font-weight: bold; padding: 3px 5px; border-top: 1px dashed #ccc; font-size: 11px;">
                            <span>RECEIPT / PAID INFORMATION :</span>
                            <div style="text-align: right;">
                                @if (Model.PaidAmount > 0) { <span>Amt: ₹ @Model.PaidAmount.ToString("N2") (@Model.PaymentMode)</span> }
                                @if (Model.MetalReceivedFineWeight > 0) { <span style="margin-left:15px;">Metal: @Model.MetalReceivedWeight.ToString("N3")g @Model.MetalReceivedType (@Model.MetalReceivedPurity%)</span> }
                            </div>
                        </div>
                    }

                    <div class="closing-balances-tax" style="margin-top: 5px; border-top: 1px dashed #333; padding-top: 5px; font-size: 11px;">
                        <div style="font-weight: bold; background: #eee; padding: 3px 5px; display: flex; justify-content: space-between;">
                            <span>CUSTOMER CLOSING BALANCE :</span>
                            <div style="display: flex; gap: 15px;">
                                <span style="color: @(amountBal >= 0 ? "#4CAF50" : "#d9534f")">Amt: ₹ @Math.Abs(amountBal).ToString("N2") @(amountBal >= 0 ? "Dr" : "Cr")</span>
                                <span>Gold: @goldBal.ToString("N3") g @(goldBal >= 0 ? "Dr" : "Cr")</span>
                                <span>Silver: @silverBal.ToString("N3") g @(silverBal >= 0 ? "Dr" : "Cr")</span>
                            </div>
                        </div>
                    </div>
                }
            }

            <div class="amount-words-tax">
                <strong>Amount in words</strong> <span class="data-field"></span>
            </div>
        </div>
        <div class="tax-totals-column">
            <div class="tax-row">
                <span class="tax-label">TOTAL</span>
                <span class="tax-val">@Model.SubTotal.ToString("N2")</span>
            </div>
            @if (Model.IGST > 0)
            {
                <div class="tax-row">
                    <span class="tax-label">IGST @(Model.GstRate.ToString("F2"))%</span>
                    <span class="tax-val">@Model.IGST.ToString("N2")</span>
                </div>
            }
            else
            {
                <div class="tax-row">
                    <span class="tax-label">SGST @((Model.GstRate / 2).ToString("F2"))%</span>
                    <span class="tax-val">@Model.SGST.ToString("N2")</span>
                </div>
                <div class="tax-row">
                    <span class="tax-label">CGST @((Model.GstRate / 2).ToString("F2"))%</span>
                    <span class="tax-val">@Model.CGST.ToString("N2")</span>
                </div>
            }
            <div class="tax-row">
                <span class="tax-label">Discount</span>
                <span class="tax-val">@Model.Discount.ToString("N2")</span>
            </div>
            <div class="tax-row grand-total-row">
                <span class="tax-label">GRAND TOTAL</span>
                <span class="tax-val">@Model.TotalAmount.ToString("N2")</span>
            </div>
        </div>
    </div>

    <div class="tax-footer-bottom">
        <div class="disclaimer-mini">
            <p>E. & O. E.</p>
            <p>All disputes subject to Jagadhri Jurisdiction only.</p>
        </div>
        <div class="for-shop-footer">
            <p class="for-jain">For @settings.ShopName</p>
            <div class="sig-section-tax">
                <div class="sig-box-tax">Customer Signature</div>
                <div class="sig-box-tax">Authorised Signature</div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --print-border: 1px solid #000;
        --print-text: #000;
    }

    .estimate-container {
        width: 210mm;
        min-height: 297mm;
        padding: 10mm;
        margin: auto;
        border: 1px solid #ccc;
        background: white;
        color: black;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .actions-bar {
        text-align: center;
        margin-bottom: 20px;
    }

    .btn {
        padding: 8px 20px;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 600;
        margin: 0 5px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary { background: #d4af37; color: white; border: none; }
    .btn-secondary { background: #333; color: white; border: none; }

    .invoice-header-top {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: bold;
        border: var(--print-border);
        border-bottom: none;
        padding: 5px 10px;
    }

    .invoice-title {
        text-align: center;
    }
    .invoice-title h2 { margin: 0; font-size: 18px; text-decoration: underline; }

    .estimate-header {
        text-align: center;
        border-left: var(--print-border);
        border-right: var(--print-border);
    }

    .top-row {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 5px 15px;
        gap: 20px;
    }

    .jj-circle {
        border: 2px solid #000;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        font-weight: bold;
    }

    .shop-name {
        font-size: 28px;
        margin: 0;
        font-weight: 900;
        letter-spacing: 2px;
    }

    .tagline {
        font-size: 11px;
        font-style: italic;
    }

    .address-bar {
        background: #000;
        color: #fff;
        padding: 4px;
        font-weight: bold;
        font-size: 12px;
    }

    .customer-info {
        border: var(--print-border);
        padding: 10px 15px;
    }

    .info-row {
        display: flex;
        margin-bottom: 5px;
        border-bottom: 1px dotted #888;
    }

    .info-item {
        flex: 1;
        font-size: 13px;
    }

    .info-item.full {
        flex: 100%;
    }

    .data-field {
        padding-left: 10px;
        font-weight: 600;
    }

    .invoice-num {
        font-size: 20px;
        font-weight: bold;
        padding-left: 10px;
    }

    .text-right { text-align: right; }
    .text-center { text-align: center; }

    .items-table {
        width: 100%;
        border-collapse: collapse;
        border: var(--print-border);
        border-top: none;
    }

    .items-table th, .items-table td {
        border-right: var(--print-border);
        border-bottom: var(--print-border);
        padding: 4px 2px;
        font-size: 10px;
        height: 22px;
    }

    .items-table th {
        background: #f0f0f0;
    }

    .amount-rs { width: 10%; text-align: right; border-right: 1px dotted #000 !important; }
    .amount-p { width: 5%; text-align: center; }

    .tax-footer-grid {
        display: flex;
        border: var(--print-border);
        border-top: none;
    }

    .bank-details-section {
        flex: 1.5;
        padding: 10px;
        font-size: 12px;
        border-right: var(--print-border);
    }
    
    .bank-title { font-weight: bold; text-decoration: underline; margin-bottom: 5px; }
    .bank-details-section p { margin: 2px 0; }
    
    .cheque-line { margin-top: 10px; border-bottom: 1px dotted #888; }
    .amount-words-tax { margin-top: 10px; border-bottom: 1px dotted #888; }

    .tax-totals-column {
        flex: 1;
    }

    .tax-row {
        display: flex;
        justify-content: space-between;
        padding: 4px 10px;
        border-bottom: 1px solid #000;
        font-size: 13px;
        font-weight: bold;
    }

    .tax-label { flex: 1; }
    .tax-val { width: 100px; text-align: right; }

    .grand-total-row {
        background: #eee;
        font-size: 15px;
        border-bottom: none;
    }

    .tax-footer-bottom {
        border: var(--print-border);
        border-top: none;
        padding: 10px;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .disclaimer-mini { font-size: 10px; }
    .for-shop-footer { text-align: right; flex: 1; }
    .for-jain { font-weight: bold; font-size: 14px; margin-bottom: 40px; }
    
    .sig-section-tax { display: flex; justify-content: space-between; gap: 20px; }
    .sig-box-tax { border-top: 1px solid #000; padding: 5px; font-weight: bold; font-size: 11px; width: 150px; text-align: center; }

    @@media print {
        @@page {
            size: A4;
            margin: 5mm;
        }
        .no-print { display: none !important; }
        .estimate-container {
            border: none;
            width: 100%;
            min-height: auto;
            padding: 0;
            margin: 0;
        }
    }
</style>
