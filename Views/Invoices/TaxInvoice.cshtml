@model JewelleryApp.Models.Jewellery.Invoice
@inject JewelleryApp.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Tax Invoice";
    var settings = Db.ShopSettings.FirstOrDefault() ?? new JewelleryApp.Models.Jewellery.ShopSetting();
    var purchases = Model.Items.Where(i => i.RI == "I").ToList();
    var exchanges = Model.Items.Where(i => i.RI == "R").ToList();

    var goldPurchased = purchases.Where(i => i.Metal == "Gold").Sum(i => i.FineWt);
    var goldReceived = exchanges.Where(i => i.Metal == "Gold").Sum(i => i.FineWt);
    var silverPurchased = purchases.Where(i => i.Metal == "Silver").Sum(i => i.FineWt);
    var silverReceived = exchanges.Where(i => i.Metal == "Silver").Sum(i => i.FineWt);

    var purchaseTotalAmt = purchases.Sum(i => i.Amount) + Model.CGST + Model.SGST + Model.IGST;
    var exchangeDeductionAmt = exchanges.Sum(i => i.Amount);
    var netBillAmt = purchaseTotalAmt - exchangeDeductionAmt - Model.Discount;
}

<div class="no-print actions-bar">
    <button onclick="window.print()" class="btn btn-primary"><i class="fas fa-print"></i> Print Tax Invoice</button>
    @if (Model.Id > 0)
    {
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Back to Details</a>
    }
    else
    {
        <button onclick="window.close()" class="btn btn-secondary">Close Preview</button>
    }
</div>

<div class="bill-container">
    <div class="bill-header">
        <div class="header-left">
            <p><strong>GSTIN:</strong> @settings.GSTIN</p>
            <p><strong>PAN:</strong> @settings.PAN</p>
        </div>
        <div class="header-center">
            <h1>TAX INVOICE</h1>
            <p>State Code: @settings.StateCode</p>
        </div>
        <div class="header-right">
            <p><strong>M:</strong> @settings.Phone1</p>
            <p><strong>M:</strong> @settings.Phone2</p>
        </div>
    </div>

    <div class="shop-details">
        <div class="logo-section">
            <div class="logo-circle">JJ</div>
        </div>
        <div class="shop-name-section">
            <h1 class="shop-name">@settings.ShopName</h1>
            <p class="tagline">@settings.Tagline</p>
            <p class="address">@settings.Address1, @settings.Address2, @settings.CityState</p>
        </div>
    </div>

    <div class="invoice-info-grid">
        <div class="info-box">
            <p><strong>Invoice No:</strong> @Model.InvoiceNo</p>
            <p><strong>Date:</strong> @Model.Date.ToString("dd-MMM-yyyy")</p>
        </div>
        <div class="info-box">
            <p><strong>Customer Name:</strong> @Model.Customer?.Name</p>
            <p><strong>Mobile:</strong> @Model.Customer?.Mobile</p>
            <p><strong>Address:</strong> @Model.Customer?.Address</p>
        </div>
    </div>

    <div class="section-title">Purchase Details</div>
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 40px;">S.No</th>
                <th>Item Name</th>
                <th style="width: 60px;">Metal</th>
                <th style="width: 80px;">Gross Wt (g)</th>
                <th style="width: 70px;">P (%)</th>
                <th style="width: 80px;">Fine Wt (g)</th>
                <th style="width: 80px;">Rate (₹/g)</th>
                <th style="width: 100px;">Metal Amt (₹)</th>
                <th style="width: 100px;">Making Charges</th>
                <th style="width: 100px; text-align: right;">Total (₹)</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < purchases.Count; i++)
            {
                var item = purchases[i];
                <tr>
                    <td class="text-center">@(i + 1)</td>
                    <td>@item.ItemName</td>
                    <td class="text-center">@item.Metal</td>
                    <td class="text-right">@item.GrossWt.ToString("N3")</td>
                    <td class="text-center">@item.Purity</td>
                    <td class="text-right">@item.FineWt.ToString("N3")</td>
                    <td class="text-right">@item.Rate.ToString("N2")</td>
                    <td class="text-right">@item.MetalAmount.ToString("N2")</td>
                    <td class="text-right">
                        @if (item.MakingPercent > 0)
                        {
                            <span>@item.MakingPercent.ToString("N1")% = @item.MakingCharges.ToString("N0")</span>
                        }
                        else
                        {
                            <span>@item.MakingCharges.ToString("N2")</span>
                        }
                    </td>
                    <td class="text-right"><strong>@item.Amount.ToString("N2")</strong></td>
                </tr>
            }
            @if (purchases.Count == 0)
            {
                <tr><td colspan="10" class="text-center" style="color:#888;">No purchase items</td></tr>
            }
        </tbody>
    </table>

    @if (exchanges.Count > 0)
    {
        <div class="section-title" style="margin-top: 15px;">Customer Exchange / Old Metal Given</div>
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 40px;">S.No</th>
                    <th>Item Name</th>
                    <th style="width: 60px;">Metal</th>
                    <th style="width: 80px;">Gross Wt (g)</th>
                    <th style="width: 70px;">P (%)</th>
                    <th style="width: 80px;">Fine Wt (g)</th>
                    <th style="width: 100px;">Deduction Rate (₹/g)</th>
                    <th style="width: 120px; text-align: right;">Deduction Amount (₹)</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < exchanges.Count; i++)
                {
                    var item = exchanges[i];
                    <tr>
                        <td class="text-center">@(i + 1)</td>
                        <td>@item.ItemName</td>
                        <td class="text-center">@item.Metal</td>
                        <td class="text-right">@item.GrossWt.ToString("N3")</td>
                        <td class="text-center">@item.Purity</td>
                        <td class="text-right">@item.FineWt.ToString("N3")</td>
                        <td class="text-right">@item.Rate.ToString("N2")</td>
                        <td class="text-right"><strong>@item.Amount.ToString("N2")</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <div class="summary-flex">
        <div class="summary-left">
            <div class="summary-box">
                <div class="summary-title">Weight Summary</div>
                <div class="summary-line"><span>Gold Purchased:</span> <strong>@goldPurchased.ToString("N3") g</strong></div>
                <div class="summary-line"><span>Silver Purchased:</span> <strong>@silverPurchased.ToString("N3") g</strong></div>
                <div class="summary-line"><span>Gold Received:</span> <strong>@goldReceived.ToString("N3") g</strong></div>
                <div class="summary-line"><span>Silver Received:</span> <strong>@silverReceived.ToString("N3") g</strong></div>
                @if (Model.BhavCutWeight > 0)
                {
                    <div class="summary-line" style="color: #d4af37; font-weight: bold;">
                        <span>Bhav Cut (@Model.BhavCutMetalType):</span> 
                        <strong>- @Model.BhavCutWeight.ToString("N3") g</strong>
                    </div>
                }
            </div>

            <div class="summary-box" style="margin-top: 10px;">
                <div class="summary-title">Customer Pending Metal Balance</div>
                @{
                    var customer = Model.Customer;
                    decimal netGoldBal = 0, netSilverBal = 0, netAmtBal = 0;
                    string goldType = "Dr", silverType = "Dr", amtType = "Dr";

                    if (customer != null)
                    {
                        // 1. Calculate Ledger Balances up to Model.Date
                        var invoiceItems = Db.InvoiceItems.Include(ii => ii.Invoice).Where(ii => ii.Invoice.CustomerId == Model.CustomerId && ii.Invoice.Date <= Model.Date).ToList();
                        var metalVouchers = Db.Vouchers.Where(v => v.AccountName == customer.Name && (v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalReceipt || v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment || (v.Type == JewelleryApp.Models.Jewellery.VoucherType.General && v.FineWeight > 0)) && v.Date <= Model.Date).ToList();
                        var voucherItems = Db.VoucherItems.Include(vi => vi.Voucher).Where(vi => vi.AccountName == customer.Name && vi.Voucher.Date <= Model.Date).ToList();

                        netGoldBal = (customer.GoldBalanceType == JewelleryApp.Models.Jewellery.BalanceType.Dr) ? customer.OpeningGold : -customer.OpeningGold;
                        netSilverBal = (customer.SilverBalanceType == JewelleryApp.Models.Jewellery.BalanceType.Dr) ? customer.OpeningSilver : -customer.OpeningSilver;
                        netAmtBal = (customer.BalanceType == JewelleryApp.Models.Jewellery.BalanceType.Dr) ? customer.OpeningBalance : -customer.OpeningBalance;

                        foreach (var item in invoiceItems) {
                            if (item.Amount > 0) continue; // Skip cash items from metal ledger
                            if (item.Metal == "Gold") { if (item.RI == "I") netGoldBal += item.FineWt; else netGoldBal -= item.FineWt; }
                            else if (item.Metal == "Silver") { if (item.RI == "I") netSilverBal += item.FineWt; else netSilverBal -= item.FineWt; }
                        }
                        foreach (var v in metalVouchers) {
                            if (v.Metal == "Gold") { if (v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment) netGoldBal += v.FineWeight; else netGoldBal -= v.FineWeight; }
                            else if (v.Metal == "Silver") { if (v.Type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment) netSilverBal += v.FineWeight; else netSilverBal -= v.FineWeight; }
                        }
                        foreach (var vi in voucherItems) netAmtBal += (vi.Debit - vi.Credit);

                        // 2. Determine Impact of Current Invoice to find Previous Balances
                        var currMetalItems = Model.Items.Where(i => i.Amount <= 0).ToList();
                        decimal goldImpact = currMetalItems.Where(i => i.Metal == "Gold" && i.RI == "I").Sum(i => i.FineWt) - currMetalItems.Where(i => i.Metal == "Gold" && i.RI == "R").Sum(i => i.FineWt);
                        decimal silverImpact = currMetalItems.Where(i => i.Metal == "Silver" && i.RI == "I").Sum(i => i.FineWt) - currMetalItems.Where(i => i.Metal == "Silver" && i.RI == "R").Sum(i => i.FineWt);

                        if (Model.BhavCutWeight > 0) {
                            if (Model.BhavCutMetalType == "Gold") goldImpact -= Model.BhavCutWeight;
                            else if (Model.BhavCutMetalType == "Silver") silverImpact -= Model.BhavCutWeight;
                        }
                        // Note: MetalReceivedFineWeight (Direct Receipt) is usually handled by a separate voucher or logic

                        decimal prevGold = netGoldBal, prevSilver = netSilverBal, prevAmt = netAmtBal;
                        decimal cashImpact = (netBillAmt - Model.PaidAmount) + Model.BhavCutCash;

                        if (Model.Id > 0) {
                            // Saved: LEDGER IS CLOSING. Substract impact.
                            prevGold = netGoldBal - goldImpact;
                            prevSilver = netSilverBal - silverImpact;
                            prevAmt = netAmtBal - cashImpact;
                        } else {
                            // Preview: LEDGER IS PREVIOUS. Add impact.
                            prevGold = netGoldBal;
                            netGoldBal = prevGold + goldImpact;
                            prevSilver = netSilverBal;
                            netSilverBal = prevSilver + silverImpact;
                            prevAmt = netAmtBal;
                            netAmtBal = prevAmt + cashImpact;
                        }

                        goldType = netGoldBal >= 0 ? "Dr" : "Cr";
                        silverType = netSilverBal >= 0 ? "Dr" : "Cr";
                        amtType = netAmtBal >= 0 ? "Dr" : "Cr";
                        ViewBag.PrevGold = prevGold;
                        ViewBag.PrevSilver = prevSilver;
                        ViewBag.PrevAmtBal = prevAmt;
                    }
                }
                @if (ViewBag.PrevGold != null && Math.Abs((decimal)ViewBag.PrevGold) > 0.0001m) {
                    decimal pg = (decimal)ViewBag.PrevGold;
                    <div class="summary-line"><span>Old Gold Bal:</span> <strong>@Math.Abs(pg).ToString("N3") g (@(pg >= 0 ? "Dr" : "Cr"))</strong></div>
                }
                <div class="summary-line"><span>Gold Pending:</span> <strong>@Math.Abs(netGoldBal).ToString("N3") g (@goldType)</strong></div>
                
                @if (ViewBag.PrevSilver != null && Math.Abs((decimal)ViewBag.PrevSilver) > 0.0001m) {
                    decimal ps = (decimal)ViewBag.PrevSilver;
                    <div class="summary-line"><span>Old Silver Bal:</span> <strong>@Math.Abs(ps).ToString("N3") g (@(ps >= 0 ? "Dr" : "Cr"))</strong></div>
                }
                <div class="summary-line"><span>Silver Pending:</span> <strong>@Math.Abs(netSilverBal).ToString("N3") g (@silverType)</strong></div>
            </div>
        </div>

        <div class="summary-right">
            <div class="summary-box payment-summary">
                <div class="summary-title">Payment Summary</div>
                <div class="summary-line"><span>Purchase Total:</span> <strong>₹ @purchases.Sum(i => i.Amount).ToString("N2")</strong></div>
                @if (Model.CGST > 0)
                {
                    <div class="summary-line"><span>CGST:</span> <strong>₹ @Model.CGST.ToString("N2")</strong></div>
                }
                @if (Model.SGST > 0)
                {
                    <div class="summary-line"><span>SGST:</span> <strong>₹ @Model.SGST.ToString("N2")</strong></div>
                }
                @if (Model.IGST > 0)
                {
                    <div class="summary-line"><span>IGST:</span> <strong>₹ @Model.IGST.ToString("N2")</strong></div>
                }
                @if (exchangeDeductionAmt > 0)
                {
                    <div class="summary-line"><span>Exchange Deduction:</span> <strong style="color:#d9534f;">₹ @exchangeDeductionAmt.ToString("N2")</strong></div>
                }
                @if (Model.Discount > 0)
                {
                    <div class="summary-line"><span>Discount:</span> <strong style="color:#d9534f;">₹ @Model.Discount.ToString("N2")</strong></div>
                }
                <div class="summary-line net-row"><span>Net Bill Amount:</span> <strong>₹ @netBillAmt.ToString("N2")</strong></div>
                @if (ViewBag.PrevAmtBal != null && Math.Abs((decimal)ViewBag.PrevAmtBal) > 0.1m)
                {
                    decimal pBal = (decimal)ViewBag.PrevAmtBal;
                    <div class="summary-line"><span>Previous Balance:</span> <strong>₹ @Math.Abs(pBal).ToString("N2") (@(pBal >= 0 ? "Dr" : "Cr"))</strong></div>
                }
                @if (Model.BhavCutCash > 0)
                {
                    <div class="summary-line" style="color: #d4af37;">
                        <span>Bhav Cut Adj:</span> 
                        <strong>₹ @Model.BhavCutCash.ToString("N2")</strong>
                    </div>
                }
                <div class="summary-line"><span>Advance Paid:</span> <strong>₹ @Model.PaidAmount.ToString("N2")</strong></div>
                <div class="summary-line final-row"><span>Final Pending Balance:</span> <strong>₹ @Math.Abs(netAmtBal).ToString("N2") (@amtType)</strong></div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Remarks))
    {
        <div class="remarks-section">
            <p><strong>Remarks:</strong> @Model.Remarks</p>
        </div>
    }
    
    <div class="footer-sections">
        <div class="bank-info">
            <p><strong>Bank Details:</strong> @settings.BankName, @settings.BankBranch</p>
            <p><strong>A/C No:</strong> @settings.AccountNo | <strong>IFSC:</strong> @settings.IFSCCode</p>
            <p style="margin-top: 5px; font-size: 10px; color: #555;">E. & O. E. All disputes subject to Jagadhri Jurisdiction only.</p>
        </div>
        <div class="signature-section">
            <div class="sig-box">
                <div class="sig-line">Authorized Signature</div>
            </div>
            <div class="sig-box">
                <div class="sig-line">Customer Signature</div>
            </div>
        </div>
    </div>
    
    <div class="thanks-msg">Thank you for your business!</div>
</div>

<style>
    .bill-container {
        width: 210mm;
        min-height: 297mm;
        padding: 15mm;
        margin: auto;
        background: white;
        color: black;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        line-height: 1.4;
    }

    .bill-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        border-bottom: 2px solid #000;
        padding-bottom: 10px;
        margin-bottom: 15px;
    }

    .header-center { text-align: center; }
    .header-center h1 { margin: 0; font-size: 24px; font-weight: 800; letter-spacing: 1px; }
    .header-left p, .header-right p, .header-center p { margin: 2px 0; font-size: 12px; }

    .shop-details {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 20px;
    }

    .logo-circle {
        width: 60px;
        height: 60px;
        border: 3px solid #000;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: 900;
    }

    .shop-name { font-size: 32px; margin: 0; font-weight: 900; color: #000; text-transform: uppercase; }
    .tagline { margin: 0; font-style: italic; color: #444; font-size: 14px; }
    .address { margin: 2px 0; font-size: 13px; color: #333; }

    .invoice-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        background: #f8f8f8;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .info-box p { margin: 4px 0; font-size: 14px; }

    .section-title {
        font-weight: 800;
        font-size: 16px;
        text-transform: uppercase;
        border-bottom: 1px solid #ddd;
        padding-bottom: 5px;
        margin-bottom: 10px;
        color: #000;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
    }

    .data-table th, .data-table td {
        border: 1px solid #ddd;
        padding: 8px;
        font-size: 12px;
    }

    .data-table th {
        background: #f0f0f0;
        text-align: left;
        font-weight: 700;
    }

    .text-center { text-align: center; }
    .text-right { text-align: right; }

    .summary-flex {
        display: flex;
        gap: 20px;
        margin-top: 20px;
    }

    .summary-left { flex: 1; }
    .summary-right { flex: 1; }

    .summary-box {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 15px;
    }

    .summary-title {
        font-weight: 800;
        font-size: 14px;
        margin-bottom: 10px;
        border-bottom: 1px solid #eee;
        padding-bottom: 5px;
    }

    .summary-line {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        margin-bottom: 6px;
    }

    .payment-summary .net-row {
        border-top: 1px solid #eee;
        padding-top: 8px;
        margin-top: 8px;
        font-weight: bold;
    }

    .payment-summary .final-row {
        background: #000;
        color: #fff;
        padding: 10px;
        border-radius: 4px;
        margin-top: 10px;
        font-size: 15px;
    }

    .remarks-section {
        margin-top: 20px;
        padding: 10px;
        background: #fdfdfd;
        border-left: 4px solid #ddd;
        font-size: 13px;
        color: #444;
    }

    .footer-sections {
        display: flex;
        justify-content: space-between;
        margin-top: 40px;
        align-items: flex-end;
    }

    .bank-info { flex: 1.5; }
    .bank-info p { margin: 2px 0; font-size: 12px; }

    .signature-section {
        flex: 1;
        display: flex;
        gap: 20px;
    }

    .sig-box {
        flex: 1;
        text-align: center;
    }

    .sig-line {
        border-top: 1px solid #000;
        margin-top: 40px;
        padding-top: 5px;
        font-weight: bold;
        font-size: 12px;
    }

    .thanks-msg {
        text-align: center;
        margin-top: 30px;
        font-weight: bold;
        font-style: italic;
        color: #555;
    }

    .actions-bar {
        text-align: center;
        margin-bottom: 20px;
        padding: 10px;
        background: #f0f0f0;
        border-radius: 8px;
    }

    .btn {
        padding: 8px 20px;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 600;
        margin: 0 5px;
        text-decoration: none;
        display: inline-block;
        border: none;
    }

    .btn-primary { background: #d4af37; color: white; }
    .btn-secondary { background: #333; color: white; }

    @@media print {
        .no-print { display: none !important; }
        body { background: white; }
        .bill-container { border: none; padding: 0; margin: 0; width: 100%; }
        @@page { margin: 10mm; }
    }
</style>
