@model JewelleryApp.Models.Jewellery.Invoice
@inject JewelleryApp.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Create Invoice";
    var settings = Db.ShopSettings.FirstOrDefault() ?? new JewelleryApp.Models.Jewellery.ShopSetting();
}

<header>
    <div class="header-title">
        <h2>Create Invoice</h2>
        <p>Generate a professional jewellery invoice for your customer</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-secondary" onclick="window.print()"><i class="fas fa-eye"></i> Preview</button>
        <button class="btn btn-primary" id="save-invoice-btn"><i class="fas fa-save"></i> Save & Print</button>
    </div>
</header>

    <!-- Row 1: Invoice Details -->
    <div class="form-row full-width">
        <section class="form-card glass flex-2">
            <h3><i class="fas fa-file-invoice"></i> Invoice Details</h3>
            <div class="form-row">
                <div class="form-group flex-1">
                    <label>Document Type</label>
                    <select id="invoice-type" class="form-control highlight-select">
                        <option value="Tax Invoice" selected>Tax Invoice</option>
                        <option value="Rough Estimate">Rough Estimate</option>
                    </select>
                </div>
                <div class="form-group flex-1">
                    <label>Invoice Number</label>
                    <input type="text" id="invoice-no" value="INV-@(DateTime.Now.ToString("yyyyMMdd"))-001" readonly class="highlight-input">
                </div>
                <div class="form-group flex-1">
                    <label>Date</label>
                    <input type="date" id="invoice-date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
            </div>
        </section>

        <section class="summary-card gold-gradient flex-1">
            <div class="summary-header">
                <span>Current Total</span>
                <h2 id="summary-total">₹ 0.00</h2>
            </div>
            <div class="summary-details">
                <div class="summary-line">
                    <span>Taxable Amt</span>
                    <span id="summary-subtotal">₹ 0.00</span>
                </div>
                <div class="summary-line">
                    <span>GST Total</span>
                    <span id="summary-gst">₹ 0.00</span>
                </div>
            </div>
        </section>
    </div>

    <!-- Row 2: Customer Selection -->
    <section class="form-card full-width glass customer-section">
        <div class="section-header">
            <h3><i class="fas fa-user-circle"></i> Customer Selection</h3>
        </div>
        <div class="form-group">
            <label>Select Customer</label>
            <div class="input-with-icon">
                <i class="fas fa-search"></i>
                <select id="cust-name-select" class="form-control premium-select">
                    <option value="">-- Select Existing Customer --</option>
                    <option value="custom" style="font-weight:bold; color:var(--primary-gold-dark);">+ New Customer (Manual Entry)</option>
                </select>
            </div>
        </div>

        <!-- Row 3: New Customer Details (Dynamic) -->
        <div id="new-cust-fields" style="display:none; transition: var(--transition); border-top: 1px dashed var(--primary-gold-light); margin-top: 20px; padding-top: 20px;">
            <div class="form-row">
                <div class="form-group col-4">
                    <label>Customer Name <span class="text-danger">*</span></label>
                    <input type="text" id="cust-name" placeholder="Enter Full Name">
                </div>
                <div class="form-group col-4">
                    <label>Mobile Number <span class="text-danger">*</span></label>
                    <input type="tel" id="cust-mobile" placeholder="+91 XXXXX XXXXX">
                </div>
                <div class="form-group col-4">
                    <label>GSTIN (Optional)</label>
                    <input type="text" id="cust-gstin" placeholder="Ex: 22AAAAA0000A1Z5">
                </div>
            </div>
            <div class="form-group">
                <label>Billing Address <span class="text-danger">*</span></label>
                <textarea id="cust-address" rows="2" placeholder="Full residential or business address..."></textarea>
            </div>
        </div>
    </section>

    <!-- Row 2: Product Table -->
    <section class="form-card full-width glass items-section">
        <div class="section-header">
            <div class="title-with-rate">
                <h3><i class="fas fa-gem"></i> Items & Products</h3>
                <div class="rate-badge">
                   <label>Gold Rate:</label>
                   <div class="input-group-small">
                       <span>₹</span>
                       <input type="number" id="daily-rate" value="@settings.DefaultGoldRate" step="1">
                       <span>/g</span>
                   </div>
                </div>
                <div class="rate-badge">
                   <label>Silver Rate:</label>
                   <div class="input-group-small">
                       <span>₹</span>
                       <input type="number" id="silver-rate" value="@settings.DefaultSilverRate" step="1">
                       <span>/g</span>
                   </div>
                </div>
            </div>
            <button type="button" class="btn btn-primary btn-add-new" id="add-row-btn">
                <i class="fas fa-plus"></i> Add New Item Line
            </button>
        </div>
        <div class="table-container">
            <table id="product-table" class="premium-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">S.No</th>
                        <th style="width: 80px;">R/I</th>
                        <th style="width: 200px;">ITEM</th>
                        <th class="bill-col-metal" style="width: 100px;">METAL</th>
                        <th style="width: 110px;">GROSS WT (g)</th>
                        <th class="bill-col-purity" style="width: 100px;">PURITY (%)</th>
                        <th class="bill-col-finewt" style="width: 100px;">FINE WT (g)</th>
                        <th class="bill-col-rate" style="width: 110px;">RATE (₹/g)</th>
                        <th class="bill-col-metalamt" style="width: 130px;">METAL AMT (₹)</th>
                        <th class="bill-col-makingpct" style="width: 100px;">MAKING %</th>
                        <th class="bill-col-makingamt" style="width: 120px;">MAKING AMT (₹)</th>
                        <th style="width: 130px;">TOTAL (₹)</th>
                        <th style="width: 40px;"></th>
                    </tr>
                </thead>
                <tbody id="invoice-items">
                    <!-- Dynamic Rows added via JS -->
                </tbody>
            </table>
        </div>
    </section>

    <!-- Payment & Additional -->
    <section class="form-card glass">
        <h3><i class="fas fa-credit-card"></i> Payment Information</h3>
        <div class="payment-modes">
            <label class="payment-option">
                <input type="radio" name="payment-mode" value="Cash" checked>
                <span class="radio-card"><i class="fas fa-money-bill-wave"></i> Cash</span>
            </label>
            <label class="payment-option">
                <input type="radio" name="payment-mode" value="UPI">
                <span class="radio-card"><i class="fas fa-mobile-alt"></i> UPI</span>
            </label>
            <label class="payment-option">
                <input type="radio" name="payment-mode" value="Card">
                <span class="radio-card"><i class="fas fa-credit-card"></i> Card</span>
            </label>
        </div>
        <div class="form-row" style="margin-top: 20px;">
            <div class="form-group flex-1">
                <label>Remarks</label>
                <input type="text" id="remarks" placeholder="Add any notes here...">
            </div>
            <div class="form-group flex-1">
                <label>Display on Print</label>
                <select id="print-option" class="form-control premium-select">
                    <option value="None">None (Standard)</option>
                    <option value="Balance">Display Pending Balance</option>
                    <option value="Weight">Display Total Metal Weight</option>
                    <option value="Both">Display Both</option>
                </select>
            </div>
        </div>
    </section>

    <!-- Grand Total Detailed -->
    <section class="form-card glass total-breakdown">
        <div class="total-row">
            <span>Metal Value</span>
            <span id="break-gold-value">₹ 0.00</span>
        </div>
        <div class="total-row">
            <span>Total Making Charges</span>
            <span id="break-making-charges">₹ 0.00</span>
        </div>
        <div class="total-row">
            <span>Sub Total:</span>
            <span id="break-sub-total">₹ 0.00</span>
        </div>
        <div id="gst-container">
            <div class="total-row" style="background: rgba(212, 175, 55, 0.05); padding: 5px 10px; border-radius: 8px;">
                <div style="display:flex; flex-direction:column; gap:5px;">
                    <label style="margin:0; font-size: 0.8rem;">GST Type</label>
                    <select id="gst-type-select" style="width: 120px; padding: 4px; font-size: 0.8rem; border-radius: 4px; border: 1px solid var(--primary-gold);">
                        <option value="intra">Intrastate (CGST+SGST)</option>
                        <option value="inter">Interstate (IGST)</option>
                    </select>
                </div>
                <div style="display:flex; flex-direction:column; gap:5px; align-items:flex-end;">
                    <label style="margin:0; font-size: 0.8rem;">GST Rate (%)</label>
                    <input type="number" id="gst-rate-input" step="0.01" value="3.00" style="width: 80px; padding: 4px; font-size: 0.8rem; border: 1px solid var(--primary-gold); text-align: center; border-radius: 4px;">
                </div>
            </div>
            <div id="cgst-sgst-rows">
                <div class="total-row">
                    <span id="label-cgst">CGST (1.5%):</span>
                    <span id="break-cgst">₹ 0.00</span>
                </div>
                <div class="total-row">
                    <span id="label-sgst">SGST (1.5%):</span>
                    <span id="break-sgst">₹ 0.00</span>
                </div>
            </div>
            <div id="igst-row" style="display:none;">
                <div class="total-row">
                    <span id="label-igst">IGST (3.0%):</span>
                    <span id="break-igst">₹ 0.00</span>
                </div>
            </div>
        </div>
        <div class="total-row" style="background: rgba(255, 0, 0, 0.03); padding: 5px 10px; border-radius: 8px;">
            <label style="margin:0; font-size: 0.8rem; color: #d9534f;">Discount (₹)</label>
            <input type="number" id="discount-input" step="0.01" value="0.00" style="width: 100px; padding: 5px; font-size: 0.9rem; border: 1px solid #d9534f; text-align: right; color: #d9534f; font-weight: bold;">
        </div>
        <div class="total-row grand">
            <span>Grand Total</span>
            <span id="break-total-amount">₹ 0.00</span>
        </div>
        <div class="total-row" style="margin-top: 20px;">
            <label style="margin:0;">Amount Paid Now (₹)</label>
            <input type="number" id="paid-amount" step="0.01" value="0.00" style="width: 150px; text-align: right;">
        </div>
        <div class="total-row rounded">
            <span>Outstanding Balance</span>
            <span id="outstanding-balance">₹ 0.00</span>
        </div>
        <div class="total-row rounded">
            <span>Rounded Off</span>
            <span id="break-rounded">₹ 0.00</span>
        </div>
        <div id="preview-weight-row" class="total-row" style="display:none; border-top: 1px dashed var(--primary-gold); margin-top: 10px; color: var(--primary-gold-dark);">
            <span><i class="fas fa-weight-hanging"></i> Total Metal Weight (To Print)</span>
            <span id="preview-total-weight">0.000 g</span>
        </div>
        <div id="preview-balance-row" class="total-row" style="display:none; border-top: 1px dashed #d9534f; margin-top: 5px; color: #d9534f;">
            <span><i class="fas fa-history"></i> Net Customer Balance (To Print)</span>
            <span id="preview-net-balance">₹ 0.00</span>
        </div>
    </section>
</div>

<!-- Bill Settings passed to JS -->
<script>
    window.BILL_SETTINGS = {
        usePurity: @(settings.UsePurity ? "true" : "false"),
        showMetal: @(settings.ShowMetalColumn ? "true" : "false"),
        showPurity: @(settings.ShowPurityColumn ? "true" : "false"),
        showFineWt: @(settings.ShowFineWtColumn ? "true" : "false"),
        showRate: @(settings.ShowRateColumn ? "true" : "false"),
        showMetalAmt: @(settings.ShowMetalAmountColumn ? "true" : "false"),
        showMakingPct: @(settings.ShowMakingPercentColumn ? "true" : "false"),
        showMakingAmt: @(settings.ShowMakingAmountColumn ? "true" : "false"),
        makingChargeType: '@settings.MakingChargeType',
        defaultMakingPercent: @settings.DefaultMakingPercent
    };
</script>

<style>
    .table-container {
        overflow-x: auto;
        margin-top: 10px;
        padding-bottom: 20px;
    }
    
    #product-table {
        min-width: 1400px; /* Wider table for new columns */
        width: 100%;
        border-collapse: collapse;
    }
    
    #product-table th, #product-table td {
        padding: 12px 8px; 
        vertical-align: middle;
        overflow: hidden;
    }

    #product-table input, #product-table select {
        width: 100%;
        min-width: 50px;
        padding: 10px;
        font-size: 0.9rem;
        border-radius: 8px;
    }

    /* Column Specific consistency */
    .huid-num { text-transform: uppercase; }
    .item-amount { color: var(--primary-gold-dark); white-space: nowrap; }
    
    .total-breakdown {
        transition: transform 0.2s ease-out;
    }
    
    @@media (max-width: 1400px) {
        .content-full { padding: 120px 20px 40px; }
    }
</style>

@section Scripts {
    <script src="~/js/premium.js"></script>
}
