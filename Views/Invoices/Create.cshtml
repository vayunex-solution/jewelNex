@model JewelleryApp.Models.Jewellery.Invoice
@inject JewelleryApp.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Create Invoice";
    var settings = Db.ShopSettings.FirstOrDefault() ?? new JewelleryApp.Models.Jewellery.ShopSetting();
}

<div class="content-full">
    <header>
        <div class="header-title">
            <h2>Create Invoice</h2>
            <p>Generate a professional jewellery invoice for your customer</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-secondary" id="preview-invoice-btn" style="margin-right: 10px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);"><i class="fas fa-eye"></i> Print Preview</button>
            <button class="btn btn-primary" id="save-invoice-btn"><i class="fas fa-save"></i> Save Invoice</button>
        </div>
    </header>

    <!-- Row 1: Invoice Details -->
    <div class="form-row full-width">
        <section class="form-card glass flex-2">
            <h3><i class="fas fa-file-invoice"></i> Invoice Details</h3>
            <div class="form-row">
                <div class="form-group flex-1">
                    <label>Document Type</label>
                    <select id="invoice-type" class="form-control highlight-select">
                        <option value="Tax Invoice" selected>Tax Invoice</option>
                        <option value="Rough Estimate">Rough Estimate</option>
                    </select>
                </div>
                <div class="form-group flex-1">
                    <label>Invoice Number</label>
                    <input type="text" id="invoice-no" value="INV-@(DateTime.Now.ToString("yyyyMMdd"))-001" readonly class="highlight-input">
                </div>
                <div class="form-group flex-1">
                    <label>Date</label>
                    <input type="date" id="invoice-date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
            </div>
        </section>

        <section class="summary-card gold-gradient flex-1">
            <div class="summary-header">
                <span>Current Total</span>
                <h2 id="summary-total">₹ 0.00</h2>
            </div>
            <div class="summary-details">
                <div class="summary-line">
                    <span>Taxable Amt</span>
                    <span id="summary-subtotal">₹ 0.00</span>
                </div>
                <div class="summary-line">
                    <span>GST Total</span>
                    <span id="summary-gst">₹ 0.00</span>
                </div>
            </div>
        </section>
    </div>

    <!-- Row 2: Customer Selection -->
    <section class="form-card full-width glass customer-section">
        <div class="section-header">
            <h3><i class="fas fa-user-circle"></i> Customer Selection</h3>
        </div>
        <div class="form-group">
            <label>Select Customer</label>
            <div class="input-with-icon">
                <i class="fas fa-search"></i>
                <select id="cust-name-select" class="form-control premium-select">
                    <option value="">-- Select Existing Customer --</option>
                    <option value="custom" style="font-weight:bold; color:var(--primary-gold-dark);">+ New Customer (Manual Entry)</option>
                </select>
            </div>
        </div>

        <!-- Dynamic Customer Balance Display -->
        <div id="customer-balance-info" style="display:none; margin-top: 15px; margin-bottom: 20px;">
            <div class="balance-grid">
                <div class="balance-item glass-mini gold">
                    <span class="label"><i class="fas fa-coins"></i> Opening Gold</span>
                    <span id="bal-gold" class="value">0.000 g</span>
                </div>
                <div class="balance-item glass-mini silver">
                    <span class="label"><i class="fas fa-ring"></i> Opening Silver</span>
                    <span id="bal-silver" class="value">0.000 g</span>
                </div>
                <div class="balance-item glass-mini amount">
                    <span class="label"><i class="fas fa-wallet"></i> Opening Amount</span>
                    <span id="bal-amount" class="value">₹ 0.00</span>
                </div>
            </div>
        </div>

        <!-- New Customer Details (Dynamic) -->
        <div id="new-cust-fields" style="display:none; transition: var(--transition); border-top: 1px dashed var(--primary-gold-light); margin-top: 20px; padding-top: 20px;">
            <div class="form-row">
                <div class="form-group col-4">
                    <label>Customer Name <span class="text-danger">*</span></label>
                    <input type="text" id="cust-name" placeholder="Enter Full Name">
                </div>
                <div class="form-group col-4">
                    <label>Mobile Number <span class="text-danger">*</span></label>
                    <input type="tel" id="cust-mobile" placeholder="+91 XXXXX XXXXX">
                </div>
                <div class="form-group col-4">
                    <label>GSTIN (Optional)</label>
                    <input type="text" id="cust-gstin" placeholder="Ex: 22AAAAA0000A1Z5">
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-4">
                    <label>Opening Amount Balance (₹)</label>
                    <div style="display:flex; gap:5px;">
                        <input type="number" id="cust-opening-bal" step="0.01" value="0" style="flex:1;">
                        <select id="cust-bal-type" style="width: 80px;">
                            <option value="1">Dr</option>
                            <option value="2">Cr</option>
                        </select>
                    </div>
                </div>
                <div class="form-group col-4">
                    <label>Opening Gold (g)</label>
                    <input type="number" id="cust-opening-gold" step="0.001" value="0.000">
                </div>
                <div class="form-group col-4">
                    <label>Opening Silver (g)</label>
                    <input type="number" id="cust-opening-silver" step="0.001" value="0.000">
                </div>
            </div>
            <div class="form-group">
                <label>Billing Address <span class="text-danger">*</span></label>
                <textarea id="cust-address" rows="2" placeholder="Full residential or business address..."></textarea>
            </div>
        </div>
    </section>

    <!-- Row 3: Product Table -->
    <section class="form-card full-width glass items-section">
        <div class="section-header">
            <div class="title-with-rate">
                <h3><i class="fas fa-gem"></i> Items & Products</h3>
                <div class="rate-badge">
                   <label>Gold Rate:</label>
                   <div class="input-group-small">
                       <span>₹</span>
                       <input type="number" id="daily-rate" value="@settings.DefaultGoldRate" step="1">
                       <span>/g</span>
                   </div>
                </div>
                <div class="rate-badge">
                   <label>Silver Rate:</label>
                   <div class="input-group-small">
                       <span>₹</span>
                       <input type="number" id="silver-rate" value="@settings.DefaultSilverRate" step="1">
                       <span>/g</span>
                   </div>
                </div>
            </div>
            <button type="button" class="btn btn-primary btn-add-new" id="add-row-btn">
                <i class="fas fa-plus"></i> Add New Item Line
            </button>
        </div>
        <div class="table-container">
            <table id="product-table" class="premium-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">S.No</th>
                        <th style="width: 80px;">R/I</th>
                        <th style="width: 200px;">ITEM</th>
                        <th class="bill-col-metal" style="width: 100px;">METAL</th>
                        <th style="width: 110px;">GROSS WT (g)</th>
                        <th class="bill-col-purity" style="width: 100px;">PURITY (%)</th>
                        <th class="bill-col-finewt" style="width: 100px;">FINE WT (g)</th>
                        <th class="bill-col-rate" style="width: 110px;">RATE (₹/g)</th>
                        <th class="bill-col-metalamt" style="width: 130px;">METAL AMT (₹)</th>
                        <th class="bill-col-makingpct" style="width: 100px;">MAKING %</th>
                        <th class="bill-col-makingamt" style="width: 120px;">MAKING AMT (₹)</th>
                        <th style="width: 130px;">TOTAL (₹)</th>
                        <th style="width: 40px;"></th>
                    </tr>
                </thead>
                <tbody id="invoice-items">
                    <!-- Dynamic Rows added via JS -->
                </tbody>
            </table>
        </div>
    </section>

    <!-- Row 4: Bhav Cut (Cash to Metal Conversion) -->
    <section class="form-card glass bhav-cut-section">
        <div class="section-header">
            <h3><i class="fas fa-cut"></i> Bhav Cut (Cash to Metal Adjustment)</h3>
            <div class="toggle-container">
                <label class="switch">
                    <input type="checkbox" id="enable-bhav-cut">
                    <span class="slider round"></span>
                </label>
                <span style="font-size: 0.85rem; color: #666; margin-left: 10px;">Enable Bhav Cut</span>
            </div>
        </div>
        <div id="bhav-cut-fields" style="display:none; transition: var(--transition);">
            <p style="font-size: 0.85rem; color: #666; margin-bottom: 15px;">Convert cash received into metal weight to adjust the customer's metal balance.</p>
            <div class="form-row">
                <div class="form-group flex-1">
                    <label>Metal Type</label>
                    <select id="bhav-cut-metal-type" class="form-control">
                        <option value="Gold">Gold</option>
                        <option value="Silver">Silver</option>
                    </select>
                </div>
                <div class="form-group flex-1">
                    <label>Cash for Conversion (₹)</label>
                    <input type="number" id="bhav-cut-cash" step="0.01" value="0.00" placeholder="Enter amount">
                </div>
                <div class="form-group flex-1">
                    <label>Conversion Rate (₹/g)</label>
                    <input type="number" id="bhav-cut-rate" step="0.01" value="0.00" placeholder="Enter rate">
                </div>
            </div>
            <div class="form-row" style="background: rgba(212, 175, 55, 0.05); padding: 15px; border-radius: 12px; align-items: center;">
                <div class="form-group" style="margin-bottom: 0;">
                    <label style="margin-bottom: 0;">Equivalent Weight Deduction:</label>
                    <div style="font-size: 1.5rem; font-weight: bold; color: var(--primary-gold-dark);" id="bhav-cut-result-raw">0.000 g</div>
                </div>
                <div class="form-group" style="margin-bottom: 0;">
                    <label>Rounded Adjustment (g)</label>
                    <input type="number" id="bhav-cut-weight" step="0.001" value="0.000" style="font-size: 1.2rem; font-weight: bold; border: 2px solid var(--primary-gold);">
                </div>
            </div>
        </div>
    </section>

    <!-- Payment & Additional -->
    <section class="form-card glass">
        <h3><i class="fas fa-credit-card"></i> Payment Information</h3>
        <div class="payment-modes">
            <label class="payment-option">
                <input type="radio" name="payment-mode" value="Cash" checked>
                <span class="radio-card"><i class="fas fa-money-bill-wave"></i> Cash</span>
            </label>
            <label class="payment-option">
                <input type="radio" name="payment-mode" value="UPI">
                <span class="radio-card"><i class="fas fa-mobile-alt"></i> UPI</span>
            </label>
            <label class="payment-option">
                <input type="radio" name="payment-mode" value="Card">
                <span class="radio-card"><i class="fas fa-credit-card"></i> Card</span>
            </label>
        </div>
        <div class="form-row" style="margin-top: 20px;">
            <div class="form-group flex-1">
                <label>Remarks</label>
                <input type="text" id="remarks" placeholder="Add any notes here...">
            </div>
            <div class="form-group flex-1">
                <label>Display on Print</label>
                <select id="print-option" class="form-control premium-select">
                    <option value="None">None (Standard)</option>
                    <option value="Balance">Display Pending Balance</option>
                    <option value="Weight">Display Total Metal Weight</option>
                    <option value="Both">Display Both</option>
                </select>
            </div>
        </div>
    </section>

    <!-- Dynamic Print Summaries -->
    <section class="form-card glass">
        <!-- Detailed Weight Summary -->
        <div id="weight-summary-section" class="weight-summary-grid" style="display:none; padding-top: 5px;">
            <div class="weight-item gold">
                <span class="label">Gold Purchased</span>
                <span id="sum-gold-purchased" class="value">0.000 g</span>
            </div>
            <div class="weight-item gold received">
                <span class="label">Gold Received</span>
                <span id="sum-gold-received" class="value">0.000 g</span>
            </div>
            <div class="weight-item silver">
                <span class="label">Silver Purchased</span>
                <span id="sum-silver-purchased" class="value">0.000 g</span>
            </div>
            <div class="weight-item silver received">
                <span class="label">Silver Received</span>
                <span id="sum-silver-received" class="value">0.000 g</span>
            </div>
        </div>

        <!-- Final Net Position Summary -->
        <div id="final-net-position" class="net-position-card" style="margin-top: 15px; border-top: 1px solid var(--primary-gold-light); padding-top: 15px;">
            <div class="section-title-mini">Customer Pending Metal Balance (After Invoice)</div>
            <div class="weight-summary-grid">
                <div class="weight-item">
                    <span class="label">Pending Gold Weight</span>
                    <span id="final-net-gold" class="value-gold">0.000 g (Dr)</span>
                </div>
                <div class="weight-item">
                    <span class="label">Pending Silver Weight</span>
                    <span id="final-net-silver" class="value-silver">0.000 g (Dr)</span>
                </div>
            </div>
        </div>

        <div id="preview-balance-row" class="total-row" style="display:none; border-top: 1px dashed #d9534f; margin-top: 15px; color: #d9534f;">
            <span><i class="fas fa-history"></i> Net Customer Balance (To Print)</span>
            <span id="preview-net-balance">₹ 0.00</span>
        </div>
    </section>

    <!-- Grand Total Detailed Breakdown -->
    <section class="form-card glass total-breakdown">
        <h3><i class="fas fa-calculator"></i> Billing Breakdown</h3>
        <div class="total-row">
            <span>Metal Value</span>
            <span id="break-gold-value">₹ 0.00</span>
        </div>
        <div class="total-row">
            <span>Total Making Charges</span>
            <span id="break-making-charges">₹ 0.00</span>
        </div>
        <div class="total-row">
            <span>Sub Total:</span>
            <span id="break-sub-total">₹ 0.00</span>
        </div>
        <div class="total-row" style="background: rgba(76, 175, 80, 0.05); padding: 5px 10px; border-radius: 8px; margin: 5px 0;">
            <span style="color: #2E7D32; font-weight: bold;">Purchase Total (Sale)</span>
            <span id="break-purchase-total" style="color: #2E7D32; font-weight: bold;">₹ 0.00</span>
        </div>
        <div class="total-row" style="background: rgba(217, 83, 79, 0.05); padding: 5px 10px; border-radius: 8px; margin: 5px 0;">
            <span style="color: #d9534f; font-weight: bold;">Exchange Deduction (Old Metal)</span>
            <span id="break-exchange-total" style="color: #d9534f; font-weight: bold;">₹ 0.00</span>
        </div>
        <div id="gst-container">
            <div class="total-row" style="background: rgba(212, 175, 55, 0.05); padding: 5px 10px; border-radius: 8px;">
                <div style="display:flex; flex-direction:column; gap:5px;">
                    <label style="margin:0; font-size: 0.8rem;">GST Type</label>
                    <select id="gst-type-select" style="width: 120px; padding: 4px; font-size: 0.8rem; border-radius: 4px; border: 1px solid var(--primary-gold);">
                        <option value="intra">Intrastate (CGST+SGST)</option>
                        <option value="inter">Interstate (IGST)</option>
                    </select>
                </div>
                <div style="display:flex; flex-direction:column; gap:5px; align-items:flex-end;">
                    <label style="margin:0; font-size: 0.8rem;">GST Rate (%)</label>
                    <input type="number" id="gst-rate-input" step="0.01" value="3.00" style="width: 80px; padding: 4px; font-size: 0.8rem; border: 1px solid var(--primary-gold); text-align: center; border-radius: 4px;">
                </div>
            </div>
            <div id="cgst-sgst-rows">
                <div class="total-row">
                    <span id="label-cgst">CGST (1.5%):</span>
                    <span id="break-cgst">₹ 0.00</span>
                </div>
                <div class="total-row">
                    <span id="label-sgst">SGST (1.5%):</span>
                    <span id="break-sgst">₹ 0.00</span>
                </div>
            </div>
            <div id="igst-row" style="display:none;">
                <div class="total-row">
                    <span id="label-igst">IGST (3.0%):</span>
                    <span id="break-igst">₹ 0.00</span>
                </div>
            </div>
        </div>
        <div class="total-row" style="background: rgba(255, 0, 0, 0.03); padding: 5px 10px; border-radius: 8px;">
            <label style="margin:0; font-size: 0.8rem; color: #d9534f;">Discount (₹)</label>
            <input type="number" id="discount-input" step="0.01" value="0.00" style="width: 100px; padding: 5px; font-size: 0.9rem; border: 1px solid #d9534f; text-align: right; color: #d9534f; font-weight: bold;">
        </div>
        <div class="total-row grand">
            <span>Grand Total (Net Bill)</span>
            <span id="break-total-amount">₹ 0.00</span>
        </div>
        <div class="total-row" style="margin-top: 20px;">
            <label style="margin:0; font-weight:bold;">Advance Paid Now (₹)</label>
            <input type="number" id="paid-amount" step="0.01" value="0.00" style="width: 150px; text-align: right; border: 2px solid #4CAF50; border-radius: 8px; font-weight:bold;">
        </div>
        <div class="total-row rounded">
            <span>Final Pending Balance</span>
            <span id="outstanding-balance">₹ 0.00</span>
        </div>
    </section>

    <!-- Final Payment Summary -->
    <section class="form-card glass" style="border-top: 3px solid var(--primary-gold); margin-top: 30px;">
        <h2 style="color: var(--primary-gold-dark); text-align: center; margin-bottom: 20px;">Payment Summary</h2>
        <div class="summary-table-container">
            <table class="premium-table" style="width: 100%; border-collapse: separate; border-spacing: 0 10px;">
                <thead>
                    <tr style="background: transparent;">
                        <th style="border-bottom: 2px solid #eee; padding-bottom: 10px; font-weight: bold; color: #666; text-align: left;">Description</th>
                        <th style="border-bottom: 2px solid #eee; padding-bottom: 10px; font-weight: bold; color: #666; text-align: right;">Amount (₹)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td style="padding: 15px 0; border-bottom: 1px solid #f5f5f5;">Purchase Total</td>
                        <td id="sum-purchase-total" style="padding: 15px 0; border-bottom: 1px solid #f5f5f5; text-align: right; font-weight: bold;">₹ 0.00</td>
                    </tr>
                    <tr>
                        <td style="padding: 15px 0; border-bottom: 1px solid #f5f5f5;">Exchange Deduction</td>
                        <td id="sum-exchange-total" style="padding: 15px 0; border-bottom: 1px solid #f5f5f5; text-align: right; color: #d9534f;">₹ 0.00</td>
                    </tr>
                    <tr>
                        <td style="padding: 15px 0; border-bottom: 1px solid #f5f5f5;">Net Bill Amount</td>
                        <td id="sum-net-bill" style="padding: 15px 0; border-bottom: 1px solid #f5f5f5; text-align: right; font-weight: bold; color: var(--primary-gold-dark); font-size: 1.1rem;">₹ 0.00</td>
                    </tr>
                    <tr>
                        <td style="padding: 15px 0; border-bottom: 1px solid #f5f5f5;">Advance Paid</td>
                        <td id="sum-advance-paid" style="padding: 15px 0; border-bottom: 1px solid #f5f5f5; text-align: right; color: #4CAF50; font-weight: bold;">₹ 0.00</td>
                    </tr>
                    <tr style="background: rgba(212, 175, 55, 0.05);">
                        <td style="padding: 15px; border-radius: 8px 0 0 8px; font-weight: 800; font-size: 1.2rem; color: var(--primary-gold-dark);">Final Pending Balance</td>
                        <td id="sum-pending-balance" style="padding: 15px; border-radius: 0 8px 8px 0; text-align: right; font-weight: 800; font-size: 1.4rem; color: #222;">₹ 0.00</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</div>

<!-- Bill Settings passed to JS -->
<script>
    window.BILL_SETTINGS = {
        usePurity: @(settings.UsePurity ? "true" : "false"),
        showMetal: @(settings.ShowMetalColumn ? "true" : "false"),
        showPurity: @(settings.ShowPurityColumn ? "true" : "false"),
        showFineWt: @(settings.ShowFineWtColumn ? "true" : "false"),
        showRate: @(settings.ShowRateColumn ? "true" : "false"),
        showMetalAmt: @(settings.ShowMetalAmountColumn ? "true" : "false"),
        showMakingPct: @(settings.ShowMakingPercentColumn ? "true" : "false"),
        showMakingAmt: @(settings.ShowMakingAmountColumn ? "true" : "false"),
        makingChargeType: '@settings.MakingChargeType',
        defaultMakingPercent: @settings.DefaultMakingPercent,
        silverMakingRate: @settings.DefaultSilverMakingRatePerKg
    };
</script>

<style>
    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 0;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 15px;
    }

    .content-full { 
        padding: 20px; 
        display: flex; 
        flex-direction: column; 
        gap: 20px; 
        width: 100%;
        max-width: 1600px;
        margin-left: auto;
        margin-right: auto;
    }
    
    /* Ensure content doesn't go under fixed sidebar if exists */
    @@media (min-width: 992px) {
        .content-full {
            padding-left: 40px;
            padding-right: 40px;
        }
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 20px;
    }

    .title-with-rate {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .payment-modes {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
        margin-bottom: 20px;
    }
    
    .payment-option { cursor: pointer; }
    .radio-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px;
        border: 2px solid rgba(0,0,0,0.05);
        border-radius: 12px;
        background: white;
        transition: all 0.2s;
        gap: 10px;
        text-align: center;
    }
    input[type="radio"]:checked + .radio-card {
        border-color: var(--primary-gold);
        background: rgba(212, 175, 55, 0.05);
        color: var(--primary-gold-dark);
    }
    .radio-card i { font-size: 1.5rem; }

    .form-row {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 15px;
    }
    .form-group { flex: 1; min-width: 200px; }
    .col-4 { flex: 1; min-width: 250px; }
    .flex-2 { flex: 2; min-width: 300px; }
    .flex-1 { flex: 1; min-width: 300px; }

    .table-container {
        overflow-x: auto;
        margin-top: 10px;
        padding-bottom: 20px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }
    
    #product-table {
        min-width: 1400px; 
        width: 100%;
        border-collapse: collapse;
    }
    
    #product-table th, #product-table td {
        padding: 12px 8px; 
        vertical-align: middle;
    }

    #product-table input, #product-table select {
        width: 100%;
        padding: 10px;
        font-size: 0.9rem;
        border-radius: 8px;
    }

    .item-amount { color: var(--primary-gold-dark); white-space: nowrap; font-weight: bold; }
    
