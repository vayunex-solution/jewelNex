@model JewelleryApp.Models.Jewellery.Customer
@{
    ViewData["Title"] = "Edit Customer";
}

<header>
    <div class="header-title">
        <h2>Edit Customer</h2>
        <p>Update client details and balances</p>
    </div>
</header>

<div class="invoice-form-grid">
    <section class="form-card glass">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <input type="hidden" asp-for="CustomerCode" />

            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="form-group">
                <label>Customer Code</label>
                <input class="form-control" value="@Model.CustomerCode" readonly style="background: rgba(255, 255, 255, 0.05); color: #999;">
            </div>

            <div class="form-group">
                <label asp-for="Name">Full Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter customer name" required>
            </div>
            <div class="form-group">
                <label asp-for="Mobile">Mobile Number</label>
                <input asp-for="Mobile" class="form-control" placeholder="+91 XXXXX XXXXX">
            </div>
            <div class="form-group">
                <label asp-for="Address">Address</label>
                <textarea asp-for="Address" class="form-control" rows="3" placeholder="Enter full address"></textarea>
            </div>

            <div class="form-row">
                <div class="form-group col-6">
                    <label asp-for="OpeningBalance">Opening Balance</label>
                    <input asp-for="OpeningBalance" type="number" step="0.01" class="form-control" placeholder="0.00">
                </div>
                <div class="form-group col-6">
                    <label asp-for="BalanceType">Balance Type</label>
                    <select asp-for="BalanceType" class="form-control">
                        <option value="1">Debit (Dr) - Customer Owes You</option>
                        <option value="2">Credit (Cr) - You Owe Customer</option>
                    </select>
                </div>
            </div>
            <div style="margin-top: 30px; display: flex; gap: 15px;">
                <button type="submit" class="btn btn-primary">Update Customer</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </section>
</div>
