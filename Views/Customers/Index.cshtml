@model IEnumerable<JewelleryApp.Models.Jewellery.Customer>
@{
    ViewData["Title"] = "Customer Master";
}

<header>
    <div class="header-title">
        <h2>Customer Master</h2>
        <p>Manage your client database</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-user-plus"></i> Add New Customer</a>
    </div>
</header>

<div class="form-card full-width glass">
    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Mobile</th>
                    <th>Address</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Name</strong></td>
                        <td>@item.Mobile</td>
                        <td>@item.Address</td>
                        <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-remove" onclick="return confirm('Delete this customer?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align: center; padding: 40px; color: #999;">
                            No customers found. Add some to enable the billing dropdown!
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
