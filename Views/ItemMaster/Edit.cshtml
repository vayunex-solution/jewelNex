@model JewelleryApp.Models.Jewellery.ItemMaster
@{
    ViewData["Title"] = "Edit Item Master";
}

<header>
    <div class="header-title">
        <h2>Edit Item Master</h2>
        <p>Modify existing product details and stock</p>
    </div>
</header>

<div class="invoice-form-grid">
    <section class="form-card glass">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            
            <div class="form-group">
                <label asp-for="Name">Item Name</label>
                <input asp-for="Name" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label asp-for="Category">Category</label>
                <select asp-for="Category" class="form-control">
                    <option value="Gold">Gold</option>
                    <option value="Silver">Silver</option>
                    <option value="Diamond">Diamond</option>
                    <option value="Platinum">Platinum</option>
                </select>
            </div>

            <div class="form-row" style="margin-top: 10px;">
                <div class="form-group flex-1">
                    <label asp-for="Purity"><i class="fas fa-certificate"></i> Purity (e.g. 22K)</label>
                    <input asp-for="Purity" class="form-control" placeholder="Ex: 22K or 18K">
                </div>
                <div class="form-group flex-1">
                    <label asp-for="OpeningStock"><i class="fas fa-boxes"></i> Opening Qty</label>
                    <input asp-for="OpeningStock" type="number" class="form-control highlight-input" style="background: rgba(212, 175, 55, 0.05);">
                </div>
                <div class="form-group flex-1">
                    <label asp-for="OpeningWeight"><i class="fas fa-weight-hanging"></i> Opening Weight</label>
                    <input asp-for="OpeningWeight" type="number" step="0.001" class="form-control highlight-input" style="background: rgba(212, 175, 55, 0.05);">
                </div>
            </div>



            <div class="form-group">
                <label asp-for="DefaultRate">Default Rate (₹/g)</label>
                <input asp-for="DefaultRate" type="number" step="0.01" class="form-control" required>
            </div>

            <div style="margin-top: 30px; display: flex; gap: 15px;">
                <button type="submit" class="btn btn-primary">Update Item</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </section>
</div>

<script>
    document.querySelector('form').addEventListener('submit', function(e) {
        const btn = this.querySelector('button[type="submit"]');
        if (btn.disabled) return;
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Updating...';
    });
</script>

@section Scripts {
    <script>
        // No client-side live calculation needed as Current fields are removed
    </script>
}
