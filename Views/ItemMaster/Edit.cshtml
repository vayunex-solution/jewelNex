@model JewelleryApp.Models.Jewellery.ItemMaster
@{
    ViewData["Title"] = "Edit Item Master";
}

<header>
    <div class="header-title">
        <h2>Edit Item Master</h2>
        <p>Modify existing product details and stock</p>
    </div>
</header>

<div class="invoice-form-grid">
    <section class="form-card glass">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            
            <div class="form-group">
                <label asp-for="Name">Item Name</label>
                <input asp-for="Name" class="form-control" required>
            </div>
            
            <div class="form-group">
                <label asp-for="Category">Category</label>
                <select asp-for="Category" class="form-control">
                    <option value="Gold">Gold</option>
                    <option value="Silver">Silver</option>
                    <option value="Diamond">Diamond</option>
                    <option value="Platinum">Platinum</option>
                </select>
            </div>

            <div class="form-row" style="margin-top: 10px;">
                <div class="form-group flex-1">
                    <label asp-for="Purity"><i class="fas fa-certificate"></i> Purity (e.g. 22K)</label>
                    <input asp-for="Purity" class="form-control" placeholder="Ex: 22K or 18K">
                </div>
                <div class="form-group flex-1">
                    <label asp-for="OpeningStock"><i class="fas fa-boxes"></i> Opening Stock</label>
                    <input asp-for="OpeningStock" type="number" class="form-control highlight-input" style="background: rgba(212, 175, 55, 0.05);">
                </div>
                <div class="form-group flex-1">
                    <label asp-for="StockQuantity"><i class="fas fa-layer-group"></i> Current Live Stock</label>
                    <div class="input-with-info">
                        <input asp-for="StockQuantity" type="number" class="form-control" readonly style="background-color: #f1f3f5; border-color: #dee2e6; color: #666; font-weight: 700;">
                        <div class="info-badge-small">
                            <i class="fas fa-magic"></i> Auto-calculated
                        </div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="TotalWeight">Total Weight (grams)</label>
                <input asp-for="TotalWeight" type="number" step="0.001" class="form-control">
            </div>

            <div class="form-group">
                <label asp-for="DefaultRate">Default Rate (₹/g)</label>
                <input asp-for="DefaultRate" type="number" step="0.01" class="form-control" required>
            </div>

            <div style="margin-top: 30px; display: flex; gap: 15px;">
                <button type="submit" class="btn btn-primary">Update Item</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <script>
        const openingStockInput = document.querySelector('input[name="OpeningStock"]');
        const currentStockInput = document.querySelector('input[name="StockQuantity"]');
        
        // Store initial values to calculate delta
        const initialOpening = parseFloat(openingStockInput.value) || 0;
        const initialCurrent = parseFloat(currentStockInput.value) || 0;

        if (openingStockInput && currentStockInput) {
            openingStockInput.addEventListener('input', () => {
                const newOpening = parseFloat(openingStockInput.value) || 0;
                
                if (initialCurrent === 0) {
                    // Initial Setup Case: If live stock is 0, just sync 1:1 with opening stock
                    currentStockInput.value = newOpening;
                } else {
                    // Maintenance Case: Calculate delta for items that already have sales/stock history
                    const delta = newOpening - initialOpening;
                    currentStockInput.value = initialCurrent + delta;
                }
            });
        }
    </script>
}
