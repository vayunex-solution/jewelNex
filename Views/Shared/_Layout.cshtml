<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jain Jewellers</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/premium/style.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <!-- Top Navigation -->
        <header class="top-nav glass">
            <div class="nav-container">
                <div class="logo">
                   <div class="logo-circle" style="background: var(--primary-gold); color: white; border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 10px;">JJ</div>
                   <h1 class="logo-text">JAIN<span>JEWELLERS</span></h1>
                </div>
                
                <nav class="main-menu">
                    <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="fas fa-th-large"></i> Dashboard
                    </a>
                    <div class="nav-item-dropdown">
                        <a href="#" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Invoices" ? "active" : "")">
                            <i class="fas fa-exchange-alt"></i> Transaction <i class="fas fa-chevron-down" style="font-size: 0.7rem; margin-left: 5px;"></i>
                        </a>
                        <div class="dropdown-menu">
                            <a asp-controller="Invoices" asp-action="Create"><i class="fas fa-file-invoice"></i> New Sales Invoice</a>
                            <a asp-controller="Invoices" asp-action="Index"><i class="fas fa-history"></i> Invoice History</a>
                            <hr style="margin: 5px 0; border: none; border-top: 1px solid rgba(255,255,255,0.05);">
                            <a asp-controller="Accounting" asp-action="Create" asp-route-type="CashPayment"><i class="fas fa-money-bill-wave"></i> Cash Module (In/Out)</a>
                            <a asp-controller="Accounting" asp-action="Create" asp-route-type="CashReceipt"><i class="fas fa-university"></i> Bank Module (Dep/With)</a>
                        </div>
                    </div>
                    <div class="nav-item-dropdown">
                        <a href="#" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Stock" ? "active" : "")">
                            <i class="fas fa-boxes"></i> Inventory <i class="fas fa-chevron-down" style="font-size: 0.7rem; margin-left: 5px;"></i>
                        </a>
                        <div class="dropdown-menu">
                            <a asp-controller="Stock" asp-action="Ledger"><i class="fas fa-list-ul"></i> Stock Ledger</a>
                            <a asp-controller="Stock" asp-action="Create" asp-route-type="Purchase"><i class="fas fa-plus-circle"></i> Add Stock (Purchase)</a>
                            <a asp-controller="Stock" asp-action="Create" asp-route-type="IssueSlip"><i class="fas fa-minus-circle"></i> Issue Stock (Slip)</a>
                        </div>
                    </div>
                    <div class="nav-item-dropdown">
                        <a href="#" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ItemMaster" || ViewContext.RouteData.Values["Controller"]?.ToString() == "Customers" ? "active" : "")">
                            <i class="fas fa-layer-group"></i> Master <i class="fas fa-chevron-down" style="font-size: 0.7rem; margin-left: 5px;"></i>
                        </a>
                        <div class="dropdown-menu">
                            <a asp-controller="ItemMaster" asp-action="Index"><i class="fas fa-gem"></i> Item Master</a>
                            <a asp-controller="Customers" asp-action="Index"><i class="fas fa-users"></i> Customers</a>
                        </div>
                    </div>
                    <div class="nav-item-dropdown">
                        <a asp-controller="Reports" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? "active" : "")">
                            <i class="fas fa-chart-line"></i> Reports <i class="fas fa-chevron-down" style="font-size: 0.7rem; margin-left: 5px;"></i>
                        </a>
                        <div class="dropdown-menu">
                            <a asp-controller="Reports" asp-action="Index"><i class="fas fa-tachometer-alt"></i> Report Summary</a>
                            <a asp-controller="Reports" asp-action="AllInvoices"><i class="fas fa-list-ul"></i> All Invoice List</a>
                        </div>
                    </div>
                    <div class="nav-item-dropdown">
                        <a asp-controller="Accounting" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Accounting" ? "active" : "")">
                            <i class="fas fa-calculator"></i> Accounting <i class="fas fa-chevron-down" style="font-size: 0.7rem; margin-left: 5px;"></i>
                        </a>
                        <div class="dropdown-menu">
                            <a asp-controller="Accounting" asp-action="Index"><i class="fas fa-history"></i> Account History</a>
                            <a asp-controller="AccountGroups" asp-action="Index"><i class="fas fa-sitemap"></i> Account Groups</a>
                            <a asp-controller="AccountHeads" asp-action="Index"><i class="fas fa-list-alt"></i> Account Heads</a>
                            <a asp-controller="Accounting" asp-action="AccountStatement"><i class="fas fa-file-invoice-dollar"></i> Account Statement</a>
                            <a asp-controller="Accounting" asp-action="Create" asp-route-type="General"><i class="fas fa-file-invoice"></i> General Voucher</a>
                            <a asp-controller="Accounting" asp-action="Create" asp-route-type="CashPayment"><i class="fas fa-hand-holding-usd"></i> Cash Payment</a>
                            <a asp-controller="Accounting" asp-action="Create" asp-route-type="CashReceipt"><i class="fas fa-file-download"></i> Cash Receipt</a>
                        </div>
                    </div>
                    <a asp-controller="Database" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Database" ? "active" : "")">
                        <i class="fas fa-database"></i> Database
                    </a>
                    <a asp-controller="Settings" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Settings" ? "active" : "")">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                </nav>

                <div class="nav-actions">
                    <button id="theme-toggle" class="theme-btn"><i class="fas fa-moon"></i></button>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="content-full">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <script>
        const themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
            themeBtn.onclick = () => {
                document.body.classList.toggle('dark');
                const isDark = document.body.classList.contains('dark');
                localStorage.setItem('theme-dark', isDark);
                themeBtn.innerHTML = isDark ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
            };
        }
        
        // Restore state on load
        if (localStorage.getItem('theme-dark') === 'true') {
            document.body.classList.add('dark');
            if(themeBtn) themeBtn.innerHTML = '<i class="fas fa-sun"></i>';
        }
    </script>
</body>
</html>
