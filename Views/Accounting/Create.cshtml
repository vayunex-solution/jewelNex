@model JewelleryApp.Models.Jewellery.Voucher
@{
    var type = (JewelleryApp.Models.Jewellery.VoucherType)ViewBag.VoucherType;
    var isReceipt = type == JewelleryApp.Models.Jewellery.VoucherType.CashReceipt || type == JewelleryApp.Models.Jewellery.VoucherType.MetalReceipt;
    var isMetal = type == JewelleryApp.Models.Jewellery.VoucherType.MetalReceipt || type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment;
    var themeClass = isReceipt ? "receipt-theme" : "payment-theme";
    if (isMetal) themeClass = isReceipt ? "metal-receipt-theme" : "metal-payment-theme";
    
    ViewData["Title"] = $"New {type.ToString()}";
}

<header>
    <div class="header-title">
        <h2 class="@(isReceipt ? "text-success" : "text-danger")">
            <i class="fas @(isMetal ? "fa-weight-hanging" : (isReceipt ? "fa-file-invoice-dollar" : "fa-hand-holding-usd"))"></i> 
            New @(type.ToString().Replace("Receipt", " Receipt").Replace("Payment", " Payment"))
        </h2>
        <p>Record a direct @(isReceipt ? "incoming" : "outgoing") @(isMetal ? "metal" : "financial") transaction</p>
    </div>
    <div class="header-actions">
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</header>

<div class="form-card glass @themeClass" style="max-width: 800px; margin: 0 auto;">
    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="Type" />
        
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="VoucherNo"></label>
                <input asp-for="VoucherNo" readonly class="text-muted" />
            </div>
            <div class="form-group col-6">
                <label asp-for="Date"></label>
                <input asp-for="Date" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="form-group">
            <div style="display:flex; justify-content:space-between; align-items:center">
                <label asp-for="AccountName">Account Name / Contact</label>
                <div id="account-balance-display" style="display:flex; gap: 5px; flex-wrap: wrap;"></div>
            </div>
            <input asp-for="AccountName" id="account-name-input" placeholder="Who is this transaction for?" list="account-list" autocomplete="off" />
            <span asp-validation-for="AccountName" class="text-danger"></span>
            <datalist id="account-list">
                @if (ViewBag.AccountSuggestions != null)
                {
                    foreach (var name in (List<string>)ViewBag.AccountSuggestions)
                    {
                        <option value="@name"></option>
                    }
                }
            </datalist>
        </div>

        @if (isMetal)
        {
            <div class="basis-selector" style="margin-bottom: 20px; padding: 15px; background: rgba(255,255,255,0.05); border-radius: 10px; border: 1px solid rgba(212, 175, 55, 0.2);">
                <label style="display: block; margin-bottom: 10px; font-weight: bold; color: var(--primary-gold);">Receipt Generation Type</label>
                <div style="display: flex; gap: 20px;">
                    <label style="display: flex; align-items: center; cursor: pointer;">
                        <input type="radio" asp-for="Basis" value="Weight" id="basis-weight" checked style="width: auto; margin-right: 8px;" />
                        By Weight (Deducts from Metal Balance)
                    </label>
                    <label style="display: flex; align-items: center; cursor: pointer;">
                        <input type="radio" asp-for="Basis" value="Amount" id="basis-amount" style="width: auto; margin-right: 8px;" />
                        By Amount (Deducts from Cash Balance)
                    </label>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-6">
                    <label asp-for="Metal"></label>
                    <select asp-for="Metal" class="form-control">
                        <option value="Gold">Gold</option>
                        <option value="Silver">Silver</option>
                    </select>
                </div>
                <div class="form-group col-6">
                    <label asp-for="Purity">Purity (%)</label>
                    <input asp-for="Purity" type="number" step="0.01" id="metal-purity" value="100.00" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-6">
                    <label asp-for="Weight">Gross Weight (g)</label>
                    <input asp-for="Weight" type="number" step="0.001" id="metal-weight" />
                </div>
                <div class="form-group col-6">
                    <label asp-for="FineWeight">Fine Weight (g)</label>
                    <input asp-for="FineWeight" type="number" step="0.001" id="metal-fine-weight" readonly class="text-muted" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-12">
                    <label asp-for="TodayRate">Today Rate (₹/g)</label>
                    <input asp-for="TodayRate" type="number" step="0.01" id="metal-today-rate" placeholder="Enter current rate for conversion" />
                </div>
            </div>
        }

        <div class="form-group">
            <label asp-for="Amount">Amount (₹)</label>
            <div class="input-with-icon">
                <i class="fas fa-rupee-sign"></i>
                <input asp-for="Amount" type="number" step="0.01" value="0" id="voucher-amount" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Particulars"></label>
            <textarea asp-for="Particulars" rows="3" placeholder="Description of the transaction..."></textarea>
        </div>

        <div class="form-group">
            <label asp-for="Remarks"></label>
            <input asp-for="Remarks" placeholder="Any internal notes?" />
        </div>

        <div style="margin-top:30px">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-save"></i> Save @(type.ToString().Replace("Receipt", " Receipt").Replace("Payment", " Payment")) Entry
            </button>
        </div>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const nameInput = document.getElementById('account-name-input');
        const balDisplay = document.getElementById('account-balance-display');

        if (nameInput) {
            nameInput.addEventListener('change', function() {
                const name = this.value;
                if (!name) {
                    balDisplay.innerHTML = '';
                    return;
                }

                fetch(`/Accounting/GetAccountBalance?name=${encodeURIComponent(name)}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.balance !== undefined) {
                            let html = `<span class="balance-badge ${data.type === 'Dr' ? 'bal-dr' : 'bal-cr'}">Bal: ₹ ${data.balance.toLocaleString('en-IN', {minimumFractionDigits: 2})} ${data.type}</span>`;
                            
                            if (data.goldBalance !== undefined) {
                                html += `<span class="balance-badge ${data.goldType === 'Dr' ? 'bal-dr' : 'bal-cr'}" style="margin-left:5px">Gold: ${data.goldBalance.toFixed(3)}g ${data.goldType}</span>`;
                            }
                            if (data.silverBalance !== undefined) {
                                html += `<span class="balance-badge ${data.silverType === 'Dr' ? 'bal-dr' : 'bal-cr'}" style="margin-left:5px">Silver: ${data.silverBalance.toFixed(3)}g ${data.silverType}</span>`;
                            }
                            
                            balDisplay.innerHTML = html;
                        } else {
                            balDisplay.innerHTML = '';
                        }
                    })
                    .catch(() => {
                        balDisplay.innerHTML = '';
                    });
            });
        }

        // Metal Calculation
        const weightInput = document.getElementById('metal-weight');
        const purityInput = document.getElementById('metal-purity');
        const fineWtInput = document.getElementById('metal-fine-weight');
        const rateInput = document.getElementById('metal-today-rate');
        const amountInput = document.getElementById('voucher-amount');

        if (weightInput && purityInput && fineWtInput) {
            const calculateFineFromWeight = () => {
                const weight = parseFloat(weightInput.value) || 0;
                const purity = parseFloat(purityInput.value) || 0;
                const fineWt = (weight * purity / 100);
                fineWtInput.value = fineWt.toFixed(3);
                
                // If "By Amount" is selected, update amount
                const basis = document.querySelector('input[name="Basis"]:checked')?.value;
                if (basis === 'Amount') {
                    const rate = parseFloat(rateInput?.value) || 0;
                    if (rate > 0) {
                        amountInput.value = (fineWt * rate).toFixed(2);
                    }
                }
            };

            const calculateFromAmount = () => {
                const amount = parseFloat(amountInput.value) || 0;
                const rate = parseFloat(rateInput.value) || 0;
                const purity = parseFloat(purityInput.value) || 100;

                if (amount > 0 && rate > 0) {
                    const fineWt = amount / rate;
                    fineWtInput.value = fineWt.toFixed(3);
                    
                    // Also update gross weight based on purity
                    if (purity > 0) {
                        weightInput.value = (fineWt * 100 / purity).toFixed(3);
                    }
                }
            };

            const handleBasisChange = () => {
                const basis = document.querySelector('input[name="Basis"]:checked')?.value;
                const basisHighlight = document.getElementById('account-balance-display');
                
                if (basis === 'Amount') {
                    basisHighlight.querySelectorAll('.balance-badge').forEach(b => {
                        if (b.textContent.includes('Bal: ₹')) b.style.boxShadow = '0 0 10px var(--primary-gold)';
                        else b.style.boxShadow = 'none';
                    });
                    // If amount is not set but weight is, calculate amount
                    if (parseFloat(amountInput.value) === 0 && parseFloat(weightInput.value) > 0) {
                        calculateFineFromWeight();
                    }
                } else {
                    basisHighlight.querySelectorAll('.balance-badge').forEach(b => {
                        if (b.textContent.includes('Gold:') || b.textContent.includes('Silver:')) b.style.boxShadow = '0 0 10px var(--primary-gold)';
                        else b.style.boxShadow = 'none';
                    });
                    // If weight is not set but amount is, calculate weight
                    if (parseFloat(weightInput.value) === 0 && parseFloat(amountInput.value) > 0) {
                        calculateFromAmount();
                    }
                }
            };

            weightInput.addEventListener('input', calculateFineFromWeight);
            purityInput.addEventListener('input', calculateFineFromWeight);
            
            if (rateInput && amountInput) {
                rateInput.addEventListener('input', calculateFromAmount);
                amountInput.addEventListener('input', calculateFromAmount);
            }

            document.querySelectorAll('input[name="Basis"]').forEach(r => {
                r.addEventListener('change', handleBasisChange);
            });
            
            // Initial trigger after small delay to let balance badges load
            setTimeout(handleBasisChange, 1000);
        }
    });
</script>

<style>
    .w-100 { width: 100%; justify-content: center; }
    .text-success { color: #28a745 !important; }
    .text-danger { color: #dc3545 !important; }
    
    .balance-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .bal-dr { background: rgba(220, 53, 69, 0.1); color: #dc3545; border: 1px solid rgba(220, 53, 69, 0.2); }
    .bal-cr { background: rgba(40, 167, 69, 0.1); color: #28a745; border: 1px solid rgba(40, 167, 69, 0.2); }

    .receipt-theme .input-with-icon i { color: #28a745; }
    .payment-theme .input-with-icon i { color: #dc3545; }
    
    .metal-receipt-theme .input-with-icon i { color: #d4af37; }
    .metal-payment-theme .input-with-icon i { color: #c0c0c0; }

    .metal-receipt-theme h2 i, .metal-receipt-theme label { color: #d4af37; }
    .metal-payment-theme h2 i, .metal-payment-theme label { color: #c0c0c0; }
    
    .receipt-theme h2 i { color: #28a745; }
    .payment-theme h2 i { color: #dc3545; }
</style>
