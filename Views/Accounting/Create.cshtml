@model JewelleryApp.Models.Jewellery.Voucher
@{
    var type = (JewelleryApp.Models.Jewellery.VoucherType)ViewBag.VoucherType;
    ViewData["Title"] = $"New {type.ToString()}";
}

<header>
    <div class="header-title">
        <h2>New @type.ToString()</h2>
        <p>Record a new accounting entry under @type.ToString() categories</p>
    </div>
    <div class="header-actions">
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</header>

<div class="form-card glass" style="max-width: 800px; margin: 0 auto;">
    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="Type" />
        
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="VoucherNo"></label>
                <input asp-for="VoucherNo" readonly class="text-muted" />
            </div>
            <div class="form-group col-6">
                <label asp-for="Date"></label>
                <input asp-for="Date" type="date" />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="AccountName">Account Name / Contact</label>
            <input asp-for="AccountName" placeholder="Who is this transaction for?" list="account-list" autocomplete="off" />
            <span asp-validation-for="AccountName" class="text-danger"></span>
            <datalist id="account-list">
                @if (ViewBag.AccountSuggestions != null)
                {
                    foreach (var name in (List<string>)ViewBag.AccountSuggestions)
                    {
                        <option value="@name"></option>
                    }
                }
            </datalist>
        </div>

        <div class="form-group">
            <label asp-for="Amount"></label>
            <div class="input-with-icon">
                <i class="fas fa-rupee-sign"></i>
                <input asp-for="Amount" type="number" step="0.01" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Particulars"></label>
            <textarea asp-for="Particulars" rows="3" placeholder="Description of the transaction..."></textarea>
        </div>

        <div class="form-group">
            <label asp-for="Remarks"></label>
            <input asp-for="Remarks" placeholder="Any internal notes?" />
        </div>

        <div style="margin-top:30px">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-save"></i> Save Voucher Entry
            </button>
        </div>
    </form>
</div>

<style>
    .w-100 { width: 100%; justify-content: center; }
</style>
