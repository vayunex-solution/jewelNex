@model JewelleryApp.Models.Jewellery.Voucher
@{
    var type = (JewelleryApp.Models.Jewellery.VoucherType)ViewBag.VoucherType;
    var isReceipt = type == JewelleryApp.Models.Jewellery.VoucherType.CashReceipt || type == JewelleryApp.Models.Jewellery.VoucherType.MetalReceipt;
    var isMetal = type == JewelleryApp.Models.Jewellery.VoucherType.MetalReceipt || type == JewelleryApp.Models.Jewellery.VoucherType.MetalPayment;
    var themeClass = isReceipt ? "receipt-theme" : "payment-theme";
    if (isMetal) themeClass = isReceipt ? "metal-receipt-theme" : "metal-payment-theme";
    
    ViewData["Title"] = $"New {type.ToString()}";
}

<header>
    <div class="header-title">
        <h2 class="@(isReceipt ? "text-success" : "text-danger")">
            <i class="fas @(isMetal ? "fa-weight-hanging" : (isReceipt ? "fa-file-invoice-dollar" : "fa-hand-holding-usd"))"></i> 
            New @(type.ToString().Replace("Receipt", " Receipt").Replace("Payment", " Payment"))
        </h2>
        <p>Record a direct @(isReceipt ? "incoming" : "outgoing") @(isMetal ? "metal" : "financial") transaction</p>
    </div>
    <div class="header-actions">
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</header>

<div class="form-card glass @themeClass" style="max-width: 800px; margin: 0 auto;">
    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="Type" />
        
        <div class="form-row">
            <div class="form-group col-6">
                <label asp-for="VoucherNo"></label>
                <input asp-for="VoucherNo" readonly class="text-muted" />
            </div>
            <div class="form-group col-6">
                <label asp-for="Date"></label>
                <input asp-for="Date" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>

        <div class="form-group">
            <div style="display:flex; justify-content:space-between; align-items:center">
                <label asp-for="AccountName">Account Name / Contact</label>
                <span id="account-balance-display" class="balance-badge" style="display:none">Bal: ₹ 0.00 Dr</span>
            </div>
            <input asp-for="AccountName" id="account-name-input" placeholder="Who is this transaction for?" list="account-list" autocomplete="off" />
            <span asp-validation-for="AccountName" class="text-danger"></span>
            <datalist id="account-list">
                @if (ViewBag.AccountSuggestions != null)
                {
                    foreach (var name in (List<string>)ViewBag.AccountSuggestions)
                    {
                        <option value="@name"></option>
                    }
                }
            </datalist>
        </div>

        @if (isMetal)
        {
            <div class="form-row">
                <div class="form-group col-6">
                    <label asp-for="Metal"></label>
                    <select asp-for="Metal" class="form-control">
                        <option value="Gold">Gold</option>
                        <option value="Silver">Silver</option>
                    </select>
                </div>
                <div class="form-group col-6">
                    <label asp-for="Purity">Purity (%)</label>
                    <input asp-for="Purity" type="number" step="0.01" id="metal-purity" value="100.00" />
                </div>
            </div>
            <div class="form-row">
                <div class="form-group col-6">
                    <label asp-for="Weight">Gross Weight (g)</label>
                    <input asp-for="Weight" type="number" step="0.001" id="metal-weight" />
                </div>
                <div class="form-group col-6">
                    <label asp-for="FineWeight">Fine Weight (g)</label>
                    <input asp-for="FineWeight" type="number" step="0.001" id="metal-fine-weight" readonly class="text-muted" />
                </div>
            </div>
        }

        <div class="form-group">
            <label asp-for="Amount">Amount (₹)</label>
            <div class="input-with-icon">
                <i class="fas fa-rupee-sign"></i>
                <input asp-for="Amount" type="number" step="0.01" value="0" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Particulars"></label>
            <textarea asp-for="Particulars" rows="3" placeholder="Description of the transaction..."></textarea>
        </div>

        <div class="form-group">
            <label asp-for="Remarks"></label>
            <input asp-for="Remarks" placeholder="Any internal notes?" />
        </div>

        <div style="margin-top:30px">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-save"></i> Save @(type.ToString().Replace("Receipt", " Receipt").Replace("Payment", " Payment")) Entry
            </button>
        </div>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const nameInput = document.getElementById('account-name-input');
        const balDisplay = document.getElementById('account-balance-display');

        if (nameInput) {
            nameInput.addEventListener('change', function() {
                const name = this.value;
                if (!name) {
                    balDisplay.style.display = 'none';
                    return;
                }

                fetch(`/Accounting/GetAccountBalance?name=${encodeURIComponent(name)}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data && data.balance !== undefined) {
                            balDisplay.textContent = `Current Bal: ₹ ${data.balance.toLocaleString('en-IN', {minimumFractionDigits: 2})} ${data.type}`;
                            balDisplay.style.display = 'inline-block';
                            balDisplay.className = 'balance-badge ' + (data.type === 'Dr' ? 'bal-dr' : 'bal-cr');
                        } else {
                            balDisplay.style.display = 'none';
                        }
                    })
                    .catch(() => {
                        balDisplay.style.display = 'none';
                    });
            });
        }

        // Metal Calculation
        const weightInput = document.getElementById('metal-weight');
        const purityInput = document.getElementById('metal-purity');
        const fineWtInput = document.getElementById('metal-fine-weight');

        if (weightInput && purityInput && fineWtInput) {
            const calculateFine = () => {
                const weight = parseFloat(weightInput.value) || 0;
                const purity = parseFloat(purityInput.value) || 0;
                fineWtInput.value = (weight * purity / 100).toFixed(3);
            };

            weightInput.addEventListener('input', calculateFine);
            purityInput.addEventListener('input', calculateFine);
        }
    });
</script>

<style>
    .w-100 { width: 100%; justify-content: center; }
    .text-success { color: #28a745 !important; }
    .text-danger { color: #dc3545 !important; }
    
    .balance-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .bal-dr { background: rgba(220, 53, 69, 0.1); color: #dc3545; border: 1px solid rgba(220, 53, 69, 0.2); }
    .bal-cr { background: rgba(40, 167, 69, 0.1); color: #28a745; border: 1px solid rgba(40, 167, 69, 0.2); }

    .receipt-theme .input-with-icon i { color: #28a745; }
    .payment-theme .input-with-icon i { color: #dc3545; }
    
    .metal-receipt-theme .input-with-icon i { color: #d4af37; }
    .metal-payment-theme .input-with-icon i { color: #c0c0c0; }

    .metal-receipt-theme h2 i, .metal-receipt-theme label { color: #d4af37; }
    .metal-payment-theme h2 i, .metal-payment-theme label { color: #c0c0c0; }
    
    .receipt-theme h2 i { color: #28a745; }
    .payment-theme h2 i { color: #dc3545; }
</style>
