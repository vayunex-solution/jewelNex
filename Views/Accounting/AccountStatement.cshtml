@model JewelleryApp.Models.ViewModels.AccountStatementViewModel
@{
    ViewData["Title"] = "Account Statement";
}

<!-- Selector Section (No print) -->
<header class="no-print">
    <div class="header-title">
        <h2>Account Statement</h2>
        <p>Generate detailed ledger reports for any account head</p>
    </div>
</header>

<div class="form-card glass no-print mb-4 mt-4">
    <form asp-action="AccountStatement" method="get">
        <div class="form-row align-items-end" style="display:flex; gap:20px; align-items:flex-end;">
            <div class="form-group mb-0" style="flex:2">
                <label>Select Account</label>
                <select name="accountId" class="premium-input" asp-items="ViewBag.Accounts">
                    <option value="">-- Select A/c Head --</option>
                </select>
            </div>
            <div class="form-group mb-0" style="flex:1">
                <label>From Date</label>
                <input type="date" name="fromDate" class="premium-input" value="@(Model?.FromDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-01"))" />
            </div>
            <div class="form-group mb-0" style="flex:1">
                <label>To Date</label>
                <input type="date" name="toDate" class="premium-input" value="@(Model?.ToDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="form-group mb-0" style="flex:1">
                <label>Display on Print</label>
                <select name="printOption" class="premium-input">
                    <option value="None" selected="@(Model?.PrintOption == "None")">None</option>
                    <option value="Balance" selected="@(Model?.PrintOption == "Balance")">Display Pending Balance</option>
                    <option value="Weight" selected="@(Model?.PrintOption == "Weight")">Display Total Metal Weight</option>
                    <option value="Both" selected="@(Model?.PrintOption == "Both")">Display Both</option>
                </select>
            </div>
            <div class="form-group mb-0">
                <button type="submit" class="btn btn-primary" style="height:45px; padding: 0 30px;">
                    <i class="fas fa-search"></i> View Statement
                </button>
            </div>
            @if (Model != null)
            {
                <div class="form-group mb-0">
                    <button type="button" class="btn btn-secondary" onclick="window.print()" style="height:45px; padding: 0 30px;">
                        <i class="fas fa-print"></i> Print
                    </button>
                </div>
            }
        </div>
    </form>
</div>

<!-- Statement Report Section -->
@if (Model != null)
{
    <div class="statement-report-container glass p-5">
        <div class="report-header text-center">
            <h1 class="shop-name">JAIN JEWELLERS</h1>
            <p class="shop-address">Premium Jewellery Lane, City Center Sector-4</p>
            <h2 class="report-title">Statement of Account</h2>
            <p class="report-dates">From <strong>@Model.FromDate.ToString("dd-MM-yyyy")</strong> to <strong>@Model.ToDate.ToString("dd-MM-yyyy")</strong></p>
        </div>

        <div class="report-meta mt-5" style="display:flex; justify-content:space-between; border-bottom: 2px solid #333; padding-bottom: 20px;">
            <div class="account-info">
                <h3 class="mb-1">@Model.Account.Name</h3>
                <p class="text-muted mb-0">Group: @Model.Account.AccountGroup?.Name</p>
                <p class="text-muted small">@Model.Account.Description</p>
            </div>
            <div class="balances text-right">
                <p class="mb-1">Printed on: @DateTime.Now.ToString("dd-MM-yyyy HH:mm")</p>
                <div class="mb-2" style="border-bottom: 1px dashed #ccc; padding-bottom: 5px; margin-bottom: 10px;">
                    <p class="mb-0 text-muted small">Opening Bal. : <strong>₹ @Model.OpeningBalance.ToString("N2") @Model.OpeningBalanceType</strong></p>
                    @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                    {
                        <div style="font-size: 0.75rem; color: #777;">
                            @if (Model.OpeningGold != 0) { <span>Gold: @Math.Abs(Model.OpeningGold).ToString("N3") g (@(Model.OpeningGold >= 0 ? "Dr" : "Cr"))</span> }
                            @if (Model.OpeningSilver != 0) { <span style="margin-left:10px;">Silver: @Math.Abs(Model.OpeningSilver).ToString("N3") g (@(Model.OpeningSilver >= 0 ? "Dr" : "Cr"))</span> }
                        </div>
                    }
                </div>
                <p class="closing-balance-summary">Closing Bal. : <strong>₹ @Model.ClosingBalance.ToString("N2") @Model.ClosingBalanceType</strong></p>
                @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                {
                    <div style="margin-top: 5px; color: var(--primary-gold-dark); line-height: 1.4;">
                        @if (Model.ClosingGold != 0) { <div>Pending Gold: <strong>@Math.Abs(Model.ClosingGold).ToString("N3") g (@(Model.ClosingGold >= 0 ? "Dr" : "Cr"))</strong></div> }
                        @if (Model.ClosingSilver != 0) { <div>Pending Silver: <strong>@Math.Abs(Model.ClosingSilver).ToString("N3") g (@(Model.ClosingSilver >= 0 ? "Dr" : "Cr"))</strong></div> }
                        <div>Total Transaction Weight: <strong>@Model.TotalWeight.ToString("N3") g</strong></div>
                    </div>
                }
            </div>
        </div>

        <div class="statement-table-wrapper mt-4">
            <table class="statement-table">
                <thead>
                    <tr>
                        <th style="width:120px">V. No.</th>
                        <th style="width:100px">Date</th>
                        <th>Description</th>
                        <th class="text-right" style="width:130px">Debit (Dr)</th>
                        <th class="text-right" style="width:130px">Credit (Cr)</th>
                        <th class="text-right" style="width:150px">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Opening Balance Row -->
                    <tr class="opening-row">
                        <td colspan="2"></td>
                        <td>
                            <div style="display:flex; flex-direction:column; gap:2px;">
                                <strong>OPENING BALANCE</strong>
                                @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                                {
                                    <div style="font-size: 0.75rem; color: #777;">
                                        @if (Model.OpeningGold != 0) { <span style="margin-right:15px;">Gold: @Model.OpeningGold.ToString("N3") g</span> }
                                        @if (Model.OpeningSilver != 0) { <span>Silver: @Model.OpeningSilver.ToString("N3") g</span> }
                                    </div>
                                }
                            </div>
                        </td>
                        <td colspan="2"></td>
                        <td class="text-right"><strong>₹ @Model.OpeningBalance.ToString("N2") @Model.OpeningBalanceType</strong></td>
                    </tr>

                    @foreach (var entry in Model.Entries)
                    {
                        <tr>
                            <td>@entry.VoucherNo</td>
                            <td>@entry.Date.ToString("dd-MM-yy")</td>
                            <td class="small-desc">@entry.Description</td>
                            
                            <td class="text-right text-dr">
                                @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                                {
                                    if (entry.WeightDebit > 0)
                                    {
                                        <div style="font-weight:600; color:@(entry.MetalType == "Gold" ? "var(--primary-gold-dark)" : "#777")">
                                            @entry.WeightDebit.ToString("N3") g
                                        </div>
                                    }
                                }
                                @if (Model.PrintOption != "Weight")
                                {
                                    if (entry.Debit > 0)
                                    {
                                        <div>₹ @entry.Debit.ToString("N2")</div>
                                    }
                                }
                            </td>
                            <td class="text-right text-cr">
                                @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                                {
                                    if (entry.WeightCredit > 0)
                                    {
                                        <div style="font-weight:600; color:@(entry.MetalType == "Gold" ? "var(--primary-gold-dark)" : "#777")">
                                            @entry.WeightCredit.ToString("N3") g
                                        </div>
                                    }
                                }
                                @if (Model.PrintOption != "Weight")
                                {
                                    if (entry.Credit > 0)
                                    {
                                        <div>₹ @entry.Credit.ToString("N2")</div>
                                    }
                                }
                            </td>
                            <td class="text-right">
                                @if (Model.PrintOption == "Weight")
                                {
                                    <strong>@entry.RunningWeight.ToString("N3") g @entry.WeightBalanceType</strong>
                                }
                                else
                                {
                                    <span>₹ @entry.RunningBalance.ToString("N2") @entry.BalanceType</span>
                                    @if (Model.PrintOption == "Both" && entry.RunningWeight != 0)
                                    {
                                        <div style="font-size: 0.75rem; color: var(--primary-gold-dark);">@entry.RunningWeight.ToString("N3")g (@entry.MetalType)</div>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="totals-row">
                        <td colspan="3" class="text-right"><strong>TOTALS</strong></td>
                        <td class="text-right">
                            <strong>
                                @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                                {
                                    <div style="color: var(--primary-gold-dark)">@Model.Entries.Sum(e => e.WeightDebit).ToString("N3") g</div>
                                }
                                @if (Model.PrintOption != "Weight")
                                {
                                    <div>₹ @Model.TotalDebit.ToString("N2")</div>
                                }
                            </strong>
                        </td>
                        <td class="text-right">
                            <strong>
                                @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                                {
                                    <div style="color: var(--primary-gold-dark)">@Model.Entries.Sum(e => e.WeightCredit).ToString("N3") g</div>
                                }
                                @if (Model.PrintOption != "Weight")
                                {
                                    <div>₹ @Model.TotalCredit.ToString("N2")</div>
                                }
                            </strong>
                        </td>
                        <td></td>
                    </tr>
                    <tr class="closing-row">
                        <td colspan="3" class="text-right"><strong>CLOSING BALANCE</strong></td>
                        <td colspan="2">
                            @if (Model.PrintOption == "Weight" || Model.PrintOption == "Both")
                            {
                                <div style="font-size: 0.75rem; color: var(--primary-gold-dark); text-align: right;">
                                    @if (Model.ClosingGold != 0) { <div>Gold: @Model.ClosingGold.ToString("N3") g</div> }
                                    @if (Model.ClosingSilver != 0) { <div>Silver: @Model.ClosingSilver.ToString("N3") g</div> }
                                </div>
                            }
                        </td>
                        <td class="text-right highlight-bal">
                            <strong>
                                @if (Model.PrintOption == "Weight")
                                {
                                    <span>As Shown Above</span>
                                }
                                else
                                {
                                    <span>₹ @Model.ClosingBalance.ToString("N2") @Model.ClosingBalanceType</span>
                                }
                            </strong>
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <div class="report-footer mt-5 p-4 text-center text-muted" style="border-top:1px dashed #ccc; font-size: 0.85rem;">
            This is a computer-generated statement and does not require a physical signature.
            <br>
            Please report any discrepancies within 7 days.
        </div>
    </div>
}
else if (ViewBag.Accounts != null)
{
    <div class="text-center p-5 mt-5">
        <i class="fas fa-file-invoice-dollar fa-4x text-muted mb-4"></i>
        <h3>Select an account to view statement</h3>
        <p class="text-muted">Use the filters above to generate a professional ledger report.</p>
    </div>
}

<style>
    .shop-name { font-size: 2.2rem; font-weight: 800; color: #222; margin-bottom: 0; }
    .report-title { color: var(--primary-gold-dark); margin-top: 20px; text-transform: uppercase; letter-spacing: 2px; }
    .text-dr { color: #d32f2f; }
    .text-cr { color: #388e3c; }
    
    .statement-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    .statement-table th { background: #f8f9fa; border-bottom: 2px solid #333; padding: 12px 10px; text-transform: uppercase; font-size: 0.8rem; }
    .statement-table td { padding: 12px 10px; border-bottom: 1px solid #eee; font-size: 0.9rem; }
    
    .opening-row td, .totals-row td, .closing-row td { background: rgba(212, 175, 55, 0.05); }
    .highlight-bal { font-size: 1.1rem; color: var(--primary-gold-dark); }
    .small-desc { max-width: 300px; line-height: 1.4; color: #555; }
    
    .text-right { text-align: right; }
    .mb-0 { margin-bottom: 0; }
    .mb-1 { margin-bottom: 0.25rem; }
    .p-5 { padding: 3rem; }
    .mt-5 { margin-top: 3rem; }
    
    .premium-input { border: 1px solid #ddd; background: white; border-radius: 10px; padding: 10px 15px; width: 100%; transition: border-color 0.3s; }

    @@media print {
        .no-print { display: none !important; }
        .statement-report-container { border: none !important; box-shadow: none !important; padding: 0 !important; width: 100% !important; }
        .app-container { display: block; }
        body { background: white !important; }
        .statement-table th { background: #eee !important; -webkit-print-color-adjust: exact; }
    }
</style>
