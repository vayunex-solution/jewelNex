@model JewelleryApp.Models.Jewellery.Voucher
@{
    ViewData["Title"] = "Voucher Details";
}

<header class="no-print">
    <div class="header-title">
        <h2>Voucher Details</h2>
        <p>Viewing entry @Model.VoucherNo</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-secondary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        <a asp-action="Index" class="btn btn-outline">Back to History</a>
    </div>
</header>

<div class="form-card glass voucher-print-area" style="max-width: 600px; margin: 40px auto; padding: 50px;">
    <div class="text-center mb-4">
        <h2 style="color:var(--primary-gold-dark)">VOUCHER</h2>
        <p class="text-muted">Transaction ID: @Model.VoucherNo</p>
    </div>

    <hr>

    <div class="voucher-details" style="margin-top:30px">
        <div class="d-flex justify-content-between mb-3">
            <strong>Date:</strong>
            <span>@Model.Date.ToString("dd MMMM yyyy")</span>
        </div>
        <div class="d-flex justify-content-between mb-3">
            <strong>Voucher Type:</strong>
            <span class="badge badge-primary">@Model.Type.ToString()</span>
        </div>
        <div class="d-flex justify-content-between mb-3">
            <strong>Account Name:</strong>
            <span>@Model.AccountName</span>
        </div>
        
        <div class="amount-box" style="background:#f8f9fa; padding: 20px; border-radius: 12px; margin: 30px 0; border: 1px solid #eee;">
            <div class="d-flex justify-content-between">
                <strong style="font-size: 1.2rem;">Total Amount:</strong>
                <strong style="font-size: 1.2rem; color:var(--primary-gold-dark)">₹ @Model.Amount.ToString("N2")</strong>
            </div>
        </div>

        <div class="mb-3">
            <strong>Description:</strong>
            <p style="background:#fff; padding: 15px; border-radius: 8px; border: 1px dotted #ccc; margin-top:10px">
                @(string.IsNullOrEmpty(Model.Particulars) ? "No description provided." : Model.Particulars)
            </p>
        </div>

        @if(!string.IsNullOrEmpty(Model.Remarks)) {
            <div class="mb-3">
                <strong>Remarks:</strong>
                <p class="text-muted">@Model.Remarks</p>
            </div>
        }
    </div>

    <div class="signatures-row mt-5 d-flex justify-content-between" style="margin-top: 60px;">
        <div style="border-top:1px solid #333; width: 150px; text-align:center; padding-top: 10px; font-size: 0.8rem;">
            Receiver's Sign
        </div>
        <div style="border-top:1px solid #333; width: 150px; text-align:center; padding-top: 10px; font-size: 0.8rem;">
            Authorized Sign
        </div>
    </div>
</div>

<style>
    .d-flex { display: flex; }
    .justify-content-between { justify-content: space-between; }
    .mb-3 { margin-bottom: 1rem; }
    .mt-5 { margin-top: 3rem; }
    .text-center { text-align: center; }
    
    @@media print {
        .no-print { display: none !important; }
        body { background: white !important; }
        .voucher-print-area { border: 1px solid #eee !important; box-shadow: none !important; margin: 0 auto !important; }
    }
</style>
