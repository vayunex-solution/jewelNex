@model JewelleryApp.Models.Jewellery.User
@{
    ViewData["Title"] = "Add New User";
}

<header>
    <div class="header-title">
        <h2>Add New User</h2>
        <p>Create a new account for system access</p>
    </div>
</header>

<div class="invoice-form-grid">
    <section class="form-card glass" style="max-width: 600px;">
        <form asp-action="Create">
            <div class="form-group">
                <label asp-for="Username">Username</label>
                <div class="input-with-icon">
                    <i class="fas fa-user-tag"></i>
                    <input asp-for="Username" class="form-control" placeholder="Choose a unique username" required>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="FullName">Full Name</label>
                <div class="input-with-icon">
                    <i class="fas fa-id-card"></i>
                    <input asp-for="FullName" class="form-control" placeholder="Enter user's full name" required>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-with-icon">
                    <i class="fas fa-key"></i>
                    <input asp-for="Password" type="text" class="form-control" placeholder="Set a secure password" required>
                </div>
                <small style="color: rgba(255,255,255,0.4); margin-top: 5px; display: block;">Note: Passwords are stored securely in the local database.</small>
            </div>

            <div class="form-group">
                <label asp-for="Role">User Role</label>
                <div class="input-with-icon">
                    <i class="fas fa-user-shield"></i>
                    <select asp-for="Role" class="form-control">
                        <option value="Admin">Administrator (Full Access)</option>
                        <option value="Staff">Staff (Restricted Access)</option>
                    </select>
                </div>
            </div>

            <div style="margin-top: 35px; display: flex; gap: 15px;">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Save User
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </section>
</div>

<style>
    .input-with-icon {
        position: relative;
    }
    .input-with-icon i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--primary-gold);
        opacity: 0.7;
    }
    .input-with-icon .form-control {
        padding-left: 45px;
    }
</style>
