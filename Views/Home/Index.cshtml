@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <div class="hero-text-area">
            <span class="welcome-tag">Premium Management Suite</span>
            <h1>Jain <span>Jewellers</span></h1>
            <p>Elegance in every craft, precision in every record. Manage your premium jewellery boutique with our state-of-the-art ERP system.</p>
            
            <div class="hero-quick-actions">
                <a asp-controller="Invoices" asp-action="Create" class="btn btn-hero-gold">
                    <i class="fas fa-plus"></i> New Transaction
                </a>
                <a asp-controller="Reports" asp-action="Index" class="btn btn-hero-outline">
                    <i class="fas fa-chart-pie"></i> View Reports
                </a>
            </div>
        </div>
        <div class="hero-image-container">
            <div class="image-frame">
                <img src="~/images/hero_gold.png" alt="Jewellery Hero" />
                <div class="frame-accent"></div>
            </div>
        </div>
    </div>
</div>

<div class="dashboard-features">
    <div class="feature-card glass">
        <i class="fas fa-gem"></i>
        <h4>1,200+</h4>
        <p>Jewellery Master Items</p>
    </div>
    <div class="feature-card glass">
        <i class="fas fa-users"></i>
        <h4>450+</h4>
        <p>Premium Customers</p>
    </div>
    <div class="feature-card glass">
        <i class="fas fa-shield-alt"></i>
        <h4>100%</h4>
        <p>Secure & Encrypted</p>
    </div>
</div>

<style>
    .dashboard-hero {
        position: relative;
        min-height: 500px;
        background: var(--secondary-charcoal);
        border-radius: 30px;
        margin-top: 10px;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding: 60px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.2);
    }
    
    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(circle at 70% 50%, rgba(212, 175, 55, 0.15) 0%, transparent 70%);
        pointer-events: none;
    }
    
    .hero-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
        width: 100%;
        z-index: 2;
    }
    
    .welcome-tag {
        display: inline-block;
        color: var(--primary-gold);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        font-size: 0.8rem;
        margin-bottom: 20px;
        border-left: 3px solid var(--primary-gold);
        padding-left: 15px;
    }
    
    .hero-text-area h1 {
        font-size: 4.5rem;
        color: white;
        margin-bottom: 25px;
        line-height: 1;
    }
    
    .hero-text-area h1 span {
        color: var(--primary-gold);
        font-weight: 300;
    }
    
    .hero-text-area p {
        color: #bbb;
        font-size: 1.2rem;
        line-height: 1.6;
        margin-bottom: 40px;
        max-width: 500px;
    }
    
    .hero-quick-actions {
        display: flex;
        gap: 20px;
    }
    
    .btn-hero-gold {
        background: var(--primary-gold);
        color: var(--secondary-charcoal);
        padding: 16px 32px;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .btn-hero-gold:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(212, 175, 55, 0.3);
        background: white;
    }
    
    .btn-hero-outline {
        border: 2px solid rgba(255,255,255,0.2);
        color: white;
        padding: 16px 32px;
        border-radius: 14px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .btn-hero-outline:hover {
        background: rgba(255,255,255,0.05);
        border-color: white;
    }
    
    .hero-image-container {
        display: flex;
        justify-content: center;
        align-items: center;
    }
    
    .image-frame {
        position: relative;
        padding: 15px;
    }
    
    .image-frame img {
        width: 100%;
        max-width: 450px;
        border-radius: 20px;
        box-shadow: 0 30px 60px rgba(0,0,0,0.5);
        transform: perspective(1000px) rotateY(-10deg) rotateX(5deg);
        transition: all 0.5s ease;
    }
    
    .image-frame:hover img {
        transform: perspective(1000px) rotateY(0) rotateX(0);
    }
    
    .frame-accent {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border: 2px solid var(--primary-gold);
        border-radius: 20px;
        transform: translate(30px, 30px);
        z-index: -1;
        opacity: 0.3;
    }
    
    .dashboard-features {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
        margin-top: 40px;
    }
    
    .feature-card {
        padding: 30px;
        text-align: center;
        border-radius: 20px;
        transition: all 0.3s ease;
    }
    
    .feature-card:hover {
        transform: translateY(-10px);
        background: white;
    }
    
    .feature-card i {
        font-size: 2.5rem;
        color: var(--primary-gold);
        margin-bottom: 20px;
    }
    
    .feature-card h4 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 5px;
    }
    
    .feature-card p {
        color: var(--text-secondary);
        font-weight: 500;
    }
    
    @@media (max-width: 1200px) {
        .hero-content {
            grid-template-columns: 1fr;
            text-align: center;
            gap: 40px;
        }
        .hero-text-area p { margin: 0 auto 40px; }
        .hero-quick-actions { justify-content: center; }
        .dashboard-hero { padding: 40px 20px; }
        .hero-text-area h1 { font-size: 3rem; }
    }
</style>
