@{
    ViewData["Title"] = "Database Management";
}

<header>
    <div class="header-title">
        <h2><i class="fas fa-database"></i> Database Management</h2>
        <p>System maintenance and data utility tools</p>
    </div>
</header>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success glass-alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger glass-alert" style="background: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.2); color: #dc3545;">
        <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
    </div>
}

<div class="invoice-form-grid">
    <!-- 1. Security Key Generator -->
    <section class="form-card glass" style="border: 2px solid var(--primary-gold); box-shadow: 0 0 20px rgba(212, 175, 55, 0.2);">
        <div class="section-header">
            <h3><i class="fas fa-key"></i> Security Key Generator (OWNER ONLY)</h3>
        </div>
        <p>Generate a unique activation key for a specific Machine ID.</p>
        
        @if (TempData["GeneratedKey"] != null)
        {
            <div class="alert alert-success" style="background: rgba(212, 175, 55, 0.1); border: 2px solid var(--primary-gold); margin-bottom: 20px; padding: 20px;">
                <p style="color: var(--primary-gold-dark); font-weight: 700; margin-bottom: 10px; font-size: 1.1rem;">✨ Your Activation Key:</p>
                <div style="font-family: monospace; font-size: 1.5rem; background: #fff; padding: 15px; border-radius: 10px; text-align: center; border: 2px dashed var(--primary-gold); color: #000;">
                    @TempData["GeneratedKey"]
                </div>
                <small style="display: block; margin-top: 10px; font-weight: 600;">Copy this key for Machine ID: @TempData["KeyForId"]</small>
            </div>
        }

        <form asp-action="GenerateKey" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Target Machine ID</label>
                <input type="text" name="targetMachineId" class="form-control" placeholder="Paste JKS-XXXX-XXXX-XXXX here" required style="font-weight: bold; border-color: var(--primary-gold-light);">
            </div>
            <div class="form-row">
                <div class="form-group flex-1">
                    <label>Validity (Days)</label>
                    <select name="validityDays" class="form-control">
                        <option value="15">15 Days (Trial)</option>
                        <option value="30">30 Days (Standard)</option>
                        <option value="90">90 Days (Quarterly)</option>
                        <option value="365">365 Days (Annual)</option>
                        <option value="0">Unlimited (Lifetime)</option>
                    </select>
                </div>
                <div class="form-group flex-1">
                    <label>Admin Password</label>
                    <input type="password" name="adminPassword" class="form-control" placeholder="" required>
                </div>
            </div>
            <button type="submit" class="btn btn-primary w-100" style="margin-top: 10px; background: var(--primary-gold); color: #000;">
                <i class="fas fa-magic"></i> Generate Security Key
            </button>
        </form>

        <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid rgba(212, 175, 55, 0.2);">
            <h4 style="color: #dc3545; margin-bottom: 15px;"><i class="fas fa-shield-alt"></i> Danger Zone: Deactivation</h4>
            <form asp-action="ClearLicense" method="post" id="deactivate-form">
                @Html.AntiForgeryToken()
                <div class="form-row" style="align-items: flex-end;">
                    <div class="form-group flex-1">
                        <label>Confirm Admin Password</label>
                        <input type="password" name="adminPassword" id="deactivate-password" class="form-control" placeholder="Enter password to lock app">
                    </div>
                    <div class="form-group" style="margin-bottom: 20px;">
                        <button type="button" class="btn btn-outline" style="border-color: #dc3545; color: #dc3545;" onclick="confirmDeactivate()">
                            <i class="fas fa-power-off"></i> Clear Registration
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </section>

    <!-- 2. Clean Database -->
    <section class="form-card glass">
        <div class="section-header">
            <h3><i class="fas fa-broom"></i> Clean Database</h3>
        </div>
        
        <div class="db-utility-info" style="margin-bottom: 25px; line-height: 1.6;">
            <p>This utility will perform a comprehensive cleanup of the system data.</p>
            
            <div class="data-status-list" style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; margin-top: 15px;">
                <h4 style="margin-bottom: 10px; color: var(--primary-gold);"><i class="fas fa-info-circle"></i> What will happen:</h4>
                <ul style="list-style: none; padding: 0;">
                    <li style="margin-bottom: 8px;"><i class="fas fa-trash-alt" style="color: #dc3545; width: 25px;"></i> All <strong>Invoices & Items</strong> will be deleted.</li>
                    <li style="margin-bottom: 8px;"><i class="fas fa-trash-alt" style="color: #dc3545; width: 25px;"></i> All <strong>Vouchers & Accounting</strong> data will be deleted.</li>
                    <li style="margin-bottom: 8px;"><i class="fas fa-trash-alt" style="color: #dc3545; width: 25px;"></i> All <strong>Customers</strong> will be removed.</li>
                    <li style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 8px; margin-top: 8px;">
                        <i class="fas fa-check-circle" style="color: #28a745; width: 25px;"></i> <strong>Item Master</strong> will be preserved.
                    </li>
                </ul>
            </div>
        </div>

        <div class="danger-zone" style="border-top: 1px solid rgba(220, 53, 69, 0.2); padding-top: 25px; margin-top: 10px;">
            <form asp-action="CleanDatabase" method="post" id="clean-db-form">
                @Html.AntiForgeryToken()
                <div class="form-group" style="margin-bottom: 20px;">
                    <label style="color: #dc3545; font-weight: 600; display: block; margin-bottom: 8px;">
                        <i class="fas fa-lock"></i> Security Password Required
                    </label>
                    <input type="password" name="password" id="db-password" class="form-control" placeholder="Enter password to confirm" 
                           style="border-color: #dc3545; background: rgba(220, 53, 69, 0.05); padding: 12px;">
                </div>
                <button type="button" class="btn btn-danger btn-large w-100" onclick="confirmCleanDB()">
                    <i class="fas fa-eraser"></i> Clean Database Now
                </button>
            </form>
        </div>
    </section>

    <!-- 3. Feature Updates -->
    <section class="form-card glass">
        <div class="section-header">
            <h3><i class="fas fa-wrench"></i> Feature Updates</h3>
        </div>
        <p>Update database structure for new features.</p>
        <div style="margin-top: 25px;">
            <form asp-action="UpdateCustomerSchema" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline w-100">
                    <i class="fas fa-database"></i> Apply Schema Fix
                </button>
            </form>
        </div>
    </section>

    <!-- 4. Information -->
    <section class="form-card glass">
        <h3><i class="fas fa-shield-alt"></i> Information</h3>
        <p>Take manual backups (<code>jewellery_v5.db</code>) regularly.</p>
        <div style="margin-top: 20px; color: var(--text-secondary); font-size: 0.9rem;">
            <p><strong>System Version:</strong> 1.5.0 Premium Gold Edition</p>
            <p><strong>Last Sync:</strong> @DateTime.Now.ToString("dd-MMM-yyyy HH:mm")</p>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        function confirmCleanDB() {
            const passwordField = document.getElementById('db-password');
            if (!passwordField.value) {
                alert("⚠️ Please enter the password.");
                passwordField.focus();
                return;
            }

            if (confirm("🚨 WARNING: This will DELETE all your local data.\n\nContinue?")) {
                document.getElementById('clean-db-form').submit();
            }
        }

        function confirmDeactivate() {
            const passwordField = document.getElementById('deactivate-password');
            if (!passwordField.value) {
                alert("⚠️ Please enter the Admin Password.");
                passwordField.focus();
                return;
            }

            if (confirm("🚨 WARNING: This will DEACTIVATE this machine.\n\nContinue?")) {
                document.getElementById('deactivate-form').submit();
            }
        }
    </script>
}

<style>
    .btn-danger { background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none; padding: 15px; border-radius: 10px; font-weight: 600; cursor: pointer; }
    .glass-alert { padding: 15px; border-radius: 8px; margin-bottom: 25px; backdrop-filter: blur(5px); }
    .form-row { display: flex; gap: 15px; }
    .flex-1 { flex: 1; }
</style>
