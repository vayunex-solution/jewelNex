@{
    ViewData["Title"] = "Database Management";
}

<header>
    <div class="header-title">
        <h2><i class="fas fa-database"></i> Database Management</h2>
        <p>System maintenance and data utility tools</p>
    </div>
</header>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success glass-alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger glass-alert" style="background: rgba(220, 53, 69, 0.1); border-color: rgba(220, 53, 69, 0.2); color: #dc3545;">
        <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
    </div>
}

<div class="invoice-form-grid">
    <section class="form-card glass">
        <div class="section-header">
            <h3><i class="fas fa-broom"></i> Clean Database</h3>
        </div>
        
        <div class="db-utility-info" style="margin-bottom: 25px; line-height: 1.6;">
            <p>This utility will perform a comprehensive cleanup of the system data. It is intended for starting a new session or clearing test data.</p>
            
            <div class="data-status-list" style="background: rgba(255,255,255,0.05); padding: 20px; border-radius: 12px; margin-top: 15px;">
                <h4 style="margin-bottom: 10px; color: var(--primary-gold);"><i class="fas fa-info-circle"></i> What will happen:</h4>
                <ul style="list-style: none; padding: 0;">
                    <li style="margin-bottom: 8px;"><i class="fas fa-trash-alt" style="color: #dc3545; width: 25px;"></i> All <strong>Invoices & Items</strong> will be deleted.</li>
                    <li style="margin-bottom: 8px;"><i class="fas fa-trash-alt" style="color: #dc3545; width: 25px;"></i> All <strong>Vouchers & Accounting</strong> data will be deleted.</li>
                    <li style="margin-bottom: 8px;"><i class="fas fa-trash-alt" style="color: #dc3545; width: 25px;"></i> All <strong>Stock Transaction</strong> history will be deleted.</li>
                    <li style="margin-bottom: 8px;"><i class="fas fa-trash-alt" style="color: #dc3545; width: 25px;"></i> All <strong>Customers</strong> will be removed.</li>
                    <li style="margin-bottom: 8px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 8px; margin-top: 8px;">
                        <i class="fas fa-check-circle" style="color: #28a745; width: 25px;"></i> <strong>Item Master (Products)</strong> will be preserved.
                    </li>
                    <li style="margin-bottom: 0;"><i class="fas fa-sync-alt" style="color: var(--secondary-blue); width: 25px;"></i> All Product <strong>Stock Balances will be reset to Zero</strong>.</li>
                </ul>
            </div>
        </div>

        <div class="danger-zone" style="border-top: 1px solid rgba(220, 53, 69, 0.2); padding-top: 25px; margin-top: 10px;">
            <p style="color: #dc3545; font-weight: 600; margin-bottom: 15px;"><i class="fas fa-exclamation-circle"></i> This operation is permanent and cannot be undone.</p>
            
            <form asp-action="CleanDatabase" method="post" id="clean-db-form">
                @Html.AntiForgeryToken()
                <button type="button" class="btn btn-danger btn-large" onclick="confirmCleanDB()">
                    <i class="fas fa-eraser"></i> Clean Database Now
                </button>
            </form>
        </div>
    </section>

    <section class="form-card glass">
        <div class="section-header">
            <h3><i class="fas fa-wrench"></i> Feature Updates</h3>
        </div>
        <p>Update database structure for new features (Opening Balance support).</p>
        <div style="margin-top: 25px;">
            <form asp-action="UpdateCustomerSchema" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline w-100">
                    <i class="fas fa-database"></i> Apply Customer Schema Fix
                </button>
            </form>
        </div>
    </section>

    <section class="form-card glass">
        <h3><i class="fas fa-shield-alt"></i> Information</h3>
        <p>Before cleaning the database or applying fixes, it is recommended to take a manual backup of your database file (<code>jewellery_v5.db</code>).</p>
        <div style="margin-top: 20px; color: var(--text-secondary); font-size: 0.9rem;">
            <p><strong>System Version:</strong> 1.5.0 Premium Gold Edition</p>
            <p><strong>Last Sync:</strong> @DateTime.Now.ToString("dd-MMM-yyyy HH:mm")</p>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        function confirmCleanDB() {
            if (confirm("🚨 ATTENTION: ARE YOU ABSOLUTELY SURE?\n\nThis will PERMANENTLY DELETE all invoices, vouchers, and customers. Your product stock will be reset to zero.\n\nThis action cannot be recovered.")) {
                if (confirm("FINAL CONFIRMATION: I understand that all transaction data will be lost forever.")) {
                    document.getElementById('clean-db-form').submit();
                }
            }
        }
    </script>
}

<style>
    .btn-danger {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        border: none;
        padding: 15px 35px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(220, 53, 69, 0.3);
    }
    .btn-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(220, 53, 69, 0.4);
    }
    .glass-alert {
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 25px;
        backdrop-filter: blur(5px);
    }
</style>
