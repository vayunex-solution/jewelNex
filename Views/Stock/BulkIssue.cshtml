@model JewelleryApp.Models.Jewellery.BulkStockEntryViewModel
@{
    ViewData["Title"] = "Bulk Issue Stock";
}

<header>
    <div class="header-title">
        <h2>Bulk Issue Slip</h2>
        <p>Issue multiple items from stock in a single transaction</p>
    </div>
</header>

<div class="form-card glass mt-4">
    <form asp-action="BulkIssue" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-row mb-4">
            <div class="form-group col-md-4">
                <label asp-for="ReferenceNo">Reference / Slip No</label>
                <input asp-for="ReferenceNo" class="premium-input" placeholder="Enter Ref No" required />
            </div>
            <div class="form-group col-md-4">
                <label asp-for="Date">Date</label>
                <input asp-for="Date" type="date" class="premium-input" required />
            </div>
            <div class="form-group col-md-4">
                <label asp-for="Remarks">Common Remarks</label>
                <input asp-for="Remarks" class="premium-input" placeholder="Optional remarks" />
            </div>
        </div>

        <div class="table-container mb-4">
            <table class="table" id="itemsTable">
                <thead>
                    <tr>
                        <th style="width: 50px;">Select</th>
                        <th>Item Name</th>
                        <th style="width: 150px;">Qty to Out</th>
                        <th style="width: 150px;">Weight to Out (g)</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Items.Count; i++)
                    {
                        <tr>
                            <td class="text-center">
                                <input type="hidden" asp-for="@Model.Items[i].ItemId" />
                                <input type="hidden" asp-for="@Model.Items[i].ItemName" />
                                <input type="checkbox" asp-for="@Model.Items[i].IsSelected" class="item-checkbox" data-index="@i" />
                            </td>
                            <td>
                                <strong>@Model.Items[i].ItemName</strong>
                            </td>
                            <td>
                                <input asp-for="@Model.Items[i].Quantity" type="number" class="premium-input qty-input" data-index="@i" disabled />
                            </td>
                            <td>
                                <input asp-for="@Model.Items[i].Weight" type="number" step="0.001" class="premium-input weight-input" data-index="@i" disabled />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-right">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="fas fa-check-circle"></i> Post Bulk Entry
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.item-checkbox').change(function () {
                var index = $(this).data('index');
                var isChecked = $(this).is(':checked');
                
                // Find inputs by data-index
                $('.qty-input[data-index="' + index + '"]').prop('disabled', !isChecked);
                $('.weight-input[data-index="' + index + '"]').prop('disabled', !isChecked);
                
                if (isChecked) {
                    $(this).closest('tr').addClass('table-active');
                    $('.qty-input[data-index="' + index + '"]').focus();
                } else {
                    $(this).closest('tr').removeClass('table-active');
                }
            });
        });
    </script>
}

<style>
    .premium-input { border: 1px solid #ddd; background: white; border-radius: 8px; padding: 8px 12px; width: 100%; }
    .premium-input:disabled { background-color: #f8f9fa; opacity: 0.6; cursor: not-allowed; }
    .table-container { background: white; border-radius: 12px; padding: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    .table th { background: #f8f9fa; border-top: none; }
    .item-checkbox { width: 20px; height: 20px; cursor: pointer; }
    .table-active { background-color: rgba(212, 175, 55, 0.1) !important; }
</style>
