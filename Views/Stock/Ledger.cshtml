@model IEnumerable<JewelleryApp.Models.Jewellery.StockEntry>
@{
    ViewData["Title"] = "Stock Ledger";
    
    var allItemsList = ViewBag.ItemsList as List<JewelleryApp.Models.Jewellery.ItemMaster> ?? new List<JewelleryApp.Models.Jewellery.ItemMaster>();
    
    var goldCategoryItems = allItemsList.Where(x => string.Equals(x.Category, "Gold", StringComparison.OrdinalIgnoreCase)).ToList();
    var silverCategoryItems = allItemsList.Where(x => string.Equals(x.Category, "Silver", StringComparison.OrdinalIgnoreCase)).ToList();

    var overallGoldOpeningQty = goldCategoryItems.Sum(x => x.OpeningStock);
    var overallGoldOpeningWeight = goldCategoryItems.Sum(x => x.OpeningWeight);

    var overallSilverOpeningQty = silverCategoryItems.Sum(x => x.OpeningStock);
    var overallSilverOpeningWeight = silverCategoryItems.Sum(x => x.OpeningWeight);
    
    var overallGoldCurrentQty = goldCategoryItems.Sum(x => x.StockQuantity);
    var overallGoldCurrentWeight = goldCategoryItems.Sum(x => x.TotalWeight);

    var overallSilverCurrentQty = silverCategoryItems.Sum(x => x.StockQuantity);
    var overallSilverCurrentWeight = silverCategoryItems.Sum(x => x.TotalWeight);
}

<header>
    <div class="header-title">
        <h2>Stock Ledger</h2>
        <p>Real-time item tracking and inventory history</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" asp-route-type="Purchase" class="btn btn-primary"><i class="fas fa-plus"></i> Add Stock</a>
        <a asp-action="Create" asp-route-type="IssueSlip" class="btn btn-secondary"><i class="fas fa-file-export"></i> Issue Stock</a>
        <button onclick="window.print()" class="btn btn-dark no-print"><i class="fas fa-print"></i> Print Ledger</button>
    </div>
</header>

<div class="overall-balance-grid mb-4 no-print">
    <!-- Gold Overall Card -->
    <div class="overall-card glass-gold">
        <div class="overall-icon">
            <i class="fas fa-coins text-gold-icon"></i>
        </div>
        <div class="overall-info">
            <span class="overall-label">Overall Gold Opening</span>
            <div class="overall-value">
                <span>@overallGoldOpeningQty <small>Pcs</small></span>
                <span class="divider">|</span>
                <span>@overallGoldOpeningWeight.ToString("N3")<small>g</small></span>
            </div>
            <div class="overall-sub-text mt-2">
                <span class="text-muted">Current Stock:</span>
                <span class="value-highlight">@overallGoldCurrentQty Pcs | @overallGoldCurrentWeight.ToString("N3")g</span>
            </div>
        </div>
    </div>

    <!-- Silver Overall Card -->
    <div class="overall-card glass-silver">
        <div class="overall-icon">
            <i class="fas fa-gem text-silver-icon"></i>
        </div>
        <div class="overall-info">
            <span class="overall-label">Overall Silver Opening</span>
            <div class="overall-value">
                <span>@overallSilverOpeningQty <small>Pcs</small></span>
                <span class="divider">|</span>
                <span>@overallSilverOpeningWeight.ToString("N3")<small>g</small></span>
            </div>
            <div class="overall-sub-text mt-2">
                <span class="text-muted">Current Stock:</span>
                <span class="value-highlight">@overallSilverCurrentQty Pcs | @overallSilverCurrentWeight.ToString("N3")g</span>
            </div>
        </div>
    </div>
</div>

<div class="form-card glass mb-4 mt-4 no-print">
    <form asp-action="Ledger" method="get">
        <div style="display:flex; gap:20px; align-items:flex-end;">
            <div style="flex:1;">
                <label>Filter by Category</label>
                <select id="categoryFilter" class="premium-input">
                    <option value="All">-- All Categories --</option>
                    @foreach (var cat in (ViewBag.ItemsList as List<JewelleryApp.Models.Jewellery.ItemMaster>).Select(x => x.Category).Distinct().OrderBy(x => x))
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div style="flex:2; position: relative;">
                <label>Select Items to Track</label>
                <div class="custom-multiselect premium-input" id="multiSelectToggle">
                    <span id="selectedCount">@(ViewBag.SelectedIds.Length > 0 ? $"{ViewBag.SelectedIds.Length} Items Selected" : "-- Select Products --")</span>
                    <i class="fas fa-chevron-down float-right mt-1"></i>
                </div>
                <div class="multiselect-dropdown glass" id="multiSelectDropdown">
                    <div class="p-2 border-bottom">
                        <button type="button" class="btn btn-sm btn-link" onclick="toggleAll(true)">Select All</button>
                        <button type="button" class="btn btn-sm btn-link text-danger" onclick="toggleAll(false)">Clear</button>
                    </div>
                    @foreach (var p in ViewBag.ItemsList as List<JewelleryApp.Models.Jewellery.ItemMaster>)
                    {
                        <div class="multiselect-option" data-category="@p.Category">
                            <input type="checkbox" name="itemIds" value="@p.Id" id="item_@p.Id" 
                                   @(Array.IndexOf(ViewBag.SelectedIds as int[], p.Id) != -1 ? "checked" : "") />
                            <label for="item_@p.Id">@p.Name</label>
                        </div>
                    }
                </div>
            </div>
            <div>
                <button type="submit" class="btn btn-primary" style="height:45px">View Ledger</button>
            </div>
        </div>
    </form>
</div>

@if (ViewBag.SelectedItems != null && (ViewBag.SelectedItems as List<JewelleryApp.Models.Jewellery.ItemMaster>).Any())
{
    var selectedItems = ViewBag.SelectedItems as List<JewelleryApp.Models.Jewellery.ItemMaster>;
    <div class="stock-summary-grid mb-4">
        @foreach (var item in selectedItems)
        {
            var itemEntries = Model.Where(m => m.ItemMasterId == item.Id).ToList();
            var ledgerQty = itemEntries.Sum(e => e.Quantity);
            var ledgerWeight = itemEntries.Sum(e => e.Weight);

            <div class="stat-card glass" style="border-left: 4px solid var(--primary-gold);">
                <div class="d-flex justify-content-between align-items-start">
                    <span class="stat-label">@item.Name</span>
                    <span class="badge badge-outline">@item.Category</span>
                </div>
                <div class="mt-2" style="font-size: 0.9rem;">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Opening:</span>
                        <span><strong>@item.OpeningStock</strong> | <strong>@item.OpeningWeight.ToString("N3")g</strong></span>
                    </div>
                    <div class="d-flex justify-content-between" style="border-top: 1px solid rgba(212, 175, 55, 0.1); padding-top: 5px;">
                        <span class="text-muted">Ledger Balance:</span>
                        <span class="text-gold"><strong>@ledgerQty</strong> | <strong>@ledgerWeight.ToString("N3")g</strong></span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="form-card full-width glass">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Product</th>
                        <th>Ref No</th>
                        <th>Entry Type</th>
                        <th class="text-right">Qty (In/Out)</th>
                        <th class="text-right">Weight (g)</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model)
                    {
                        <tr>
                            <td>@entry.Date.ToString("dd MMM yyyy")</td>
                            <td><strong>@(entry.Item?.Name ?? "Unknown")</strong></td>
                            <td><strong>@entry.ReferenceNo</strong></td>
                            <td><span class="badge badge-outline">@entry.Type</span></td>
                            <td class="text-right @(entry.Quantity > 0 ? "text-success" : "text-danger")">
                                @(entry.Quantity > 0 ? "+" : "")@entry.Quantity
                            </td>
                            <td class="text-right @(entry.Weight > 0 ? "text-success" : "text-danger")">
                                @(entry.Weight > 0 ? "+" : "")@entry.Weight.ToString("N3")
                            </td>
                            <td><small class="text-muted">@entry.Remarks</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<style>
    .overall-balance-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 25px;
    }
    .overall-card {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 24px 30px;
        border-radius: 16px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.05);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
        overflow: hidden;
    }
    .overall-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 100%);
        pointer-events: none;
    }
    .overall-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px 0 rgba(31, 38, 135, 0.1);
    }
    .glass-gold {
        background: rgba(212, 175, 55, 0.08);
        border: 1px solid rgba(212, 175, 55, 0.25);
        border-left: 6px solid #D4AF37;
    }
    .glass-silver {
        background: rgba(192, 192, 192, 0.1);
        border: 1px solid rgba(192, 192, 192, 0.3);
        border-left: 6px solid #A0A0A0;
    }
    .overall-icon {
        width: 54px;
        height: 54px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        background: rgba(255, 255, 255, 0.6);
        box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }
    .text-gold-icon {
        color: #D4AF37;
    }
    .text-silver-icon {
        color: #8A8D8F;
    }
    .overall-info {
        flex: 1;
    }
    .overall-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--text-secondary);
        letter-spacing: 1.2px;
        text-transform: uppercase;
        display: block;
        margin-bottom: 4px;
    }
    .overall-value {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--secondary-charcoal);
        display: flex;
        align-items: baseline;
        gap: 8px;
    }
    .overall-value small {
        font-size: 0.95rem;
        font-weight: 600;
        color: #777;
    }
    .overall-value .divider {
        color: rgba(0,0,0,0.15);
        font-weight: 300;
        font-size: 1.4rem;
        margin: 0 2px;
    }
    .overall-sub-text {
        font-size: 0.88rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px dashed rgba(0, 0, 0, 0.08);
        padding-top: 8px;
    }
    .value-highlight {
        font-weight: 600;
        color: var(--secondary-charcoal-light);
    }

    .stock-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }
    .text-success { color: #28a745; }
    .text-danger { color: #dc3545; }
    .text-right { text-align: right; }
    .premium-input { border: 1px solid #ddd; background: white; border-radius: 10px; padding: 10px 15px; width: 100%; cursor: pointer; }
    
    @@media print {
        .no-print, header, .header-actions, .actions-bar, .sidebar, nav { display: none !important; }
        .glass { background: white !important; border: none !important; box-shadow: none !important; }
        body { background: white !important; }
        .form-card { margin: 0 !important; padding: 0 !important; width: 100% !important; max-width: 100% !important; }
        .stat-card { border: 1px solid #eee !important; page-break-inside: avoid; }
        .table-container { box-shadow: none !important; }
    }
    
    .custom-multiselect { position: relative; display: flex; justify-content: space-between; align-items: center; min-height: 45px; }
    .multiselect-dropdown { 
        position: absolute; top: 100%; left: 0; right: 0; z-index: 1000; 
        max-height: 300px; overflow-y: auto; display: none; 
        margin-top: 5px; border: 1px solid #ddd; border-radius: 10px;
        background: white; padding: 5px 0;
    }
    .multiselect-option { padding: 8px 15px; display: flex; align-items: center; gap: 10px; transition: 0.2s; }
    .multiselect-option:hover { background: #f8f9fa; }
    .multiselect-option input { width: 18px; height: 18px; cursor: pointer; }
    .multiselect-option label { margin: 0; cursor: pointer; flex: 1; }
    .float-right { float: right; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggle = document.getElementById('multiSelectToggle');
        const dropdown = document.getElementById('multiSelectDropdown');
        
        toggle.addEventListener('click', function(e) {
            e.stopPropagation();
            dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';
        });
        
        document.addEventListener('click', function() {
            dropdown.style.display = 'none';
        });
        
        dropdown.addEventListener('click', function(e) {
            e.stopPropagation();
        });

        // Update count on change
        const checkboxes = dropdown.querySelectorAll('input[type="checkbox"]');
        const countSpan = document.getElementById('selectedCount');
        
        checkboxes.forEach(cb => {
            cb.addEventListener('change', function() {
                const checked = dropdown.querySelectorAll('input[type="checkbox"]:checked');
                countSpan.innerText = checked.length > 0 ? checked.length + ' Items Selected' : '-- Select Products --';
            });
        });

        // Category Filter Logic
        const catFilter = document.getElementById('categoryFilter');
        catFilter.addEventListener('change', function() {
            const selectedCat = this.value;
            const options = dropdown.querySelectorAll('.multiselect-option');
            
            options.forEach(opt => {
                if (selectedCat === "All" || opt.getAttribute('data-category') === selectedCat) {
                    opt.style.display = 'flex';
                } else {
                    opt.style.display = 'none';
                }
            });

            // Optional: Update Select All label
            const selectAllBtn = dropdown.querySelector('button[onclick="toggleAll(true)"]');
            if (selectedCat !== "All") {
                selectAllBtn.innerText = "Select All " + selectedCat;
            } else {
                selectAllBtn.innerText = "Select All";
            }
        });
    });

    function toggleAll(select) {
        const selectedCat = document.getElementById('categoryFilter').value;
        const options = document.querySelectorAll('#multiSelectDropdown .multiselect-option');
        
        let count = 0;
        options.forEach(opt => {
            const cb = opt.querySelector('input[type="checkbox"]');
            if (selectedCat === "All" || opt.getAttribute('data-category') === selectedCat) {
                cb.checked = select;
            }
            if (cb.checked) count++;
        });

        const countSpan = document.getElementById('selectedCount');
        countSpan.innerText = count > 0 ? count + ' Items Selected' : '-- Select Products --';
    }
</script>
