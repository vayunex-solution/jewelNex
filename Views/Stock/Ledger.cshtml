@model IEnumerable<JewelleryApp.Models.Jewellery.StockEntry>
@{
    ViewData["Title"] = "Stock Ledger";
    var item = ViewBag.SelectedItem as JewelleryApp.Models.Jewellery.ItemMaster;
}

<header>
    <div class="header-title">
        <h2>Stock Ledger</h2>
        <p>Real-time item tracking and inventory history</p>
    </div>
    <div class="header-actions">
        <a asp-action="Create" asp-route-type="Purchase" class="btn btn-primary"><i class="fas fa-plus"></i> Add Stock</a>
        <a asp-action="Create" asp-route-type="IssueSlip" class="btn btn-secondary"><i class="fas fa-file-export"></i> Issue Stock</a>
    </div>
</header>

<div class="form-card glass mb-4 mt-4 no-print">
    <form asp-action="Ledger" method="get">
        <div style="display:flex; gap:20px; align-items:flex-end;">
            <div style="flex:1">
                <label>Select Item to Track</label>
                <select name="itemId" asp-items="ViewBag.Items" class="premium-input" onchange="this.form.submit()">
                    <option value="">-- Select Product --</option>
                </select>
            </div>
            <div>
                <button type="submit" class="btn btn-primary" style="height:45px">View Ledger</button>
            </div>
        </div>
    </form>
</div>

@if (item != null)
{
    <div class="stock-summary-grid mb-4">
        <div class="stat-card glass">
            <span class="stat-label">Product Name</span>
            <h3 class="stat-value">@item.Name</h3>
        </div>
        <div class="stat-card glass">
            <span class="stat-label">Opening Stock</span>
            <h3 class="stat-value">@item.OpeningStock</h3>
        </div>
        <div class="stat-card glass">
            <span class="stat-label">Current Qty</span>
            <h3 class="stat-value text-gold">@item.StockQuantity</h3>
        </div>
        <div class="stat-card glass">
            <span class="stat-label">Current Weight</span>
            <h3 class="stat-value text-gold">@item.TotalWeight.ToString("N3") g</h3>
        </div>
    </div>

    <div class="form-card full-width glass">
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Ref No</th>
                        <th>Entry Type</th>
                        <th class="text-right">Qty (In/Out)</th>
                        <th class="text-right">Weight (g)</th>
                        <th class="text-right">Running Qty</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int runningQty = item.OpeningStock;
                    }
                    @foreach (var entry in Model)
                    {
                        runningQty += entry.Quantity;
                        <tr>
                            <td>@entry.Date.ToString("dd MMM yyyy")</td>
                            <td><strong>@entry.ReferenceNo</strong></td>
                            <td><span class="badge badge-outline">@entry.Type</span></td>
                            <td class="text-right @(entry.Quantity > 0 ? "text-success" : "text-danger")">
                                @(entry.Quantity > 0 ? "+" : "")@entry.Quantity
                            </td>
                            <td class="text-right @(entry.Weight > 0 ? "text-success" : "text-danger")">
                                @(entry.Weight > 0 ? "+" : "")@entry.Weight.ToString("N3")
                            </td>
                            <td class="text-right fw-bold">@runningQty</td>
                            <td><small class="text-muted">@entry.Remarks</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<style>
    .stock-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }
    .text-success { color: #28a745; }
    .text-danger { color: #dc3545; }
    .text-right { text-align: right; }
    .premium-input { border: 1px solid #ddd; background: white; border-radius: 10px; padding: 10px 15px; width: 100%; }
</style>
